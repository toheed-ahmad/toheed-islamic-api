  },
  "ayahs": [
    {
      "ayahNumber": 4631,
      "ayahNumberInSurah": 1,
      "text": " قٓ ۚ وَٱلْقُرْءَانِ ٱلْمَجِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4632,
      "ayahNumberInSurah": 2,
      "text": "بَلْ عَجِبُوٓا۟ أَن جَآءَهُم مُّنذِرٌۭ مِّنْهُمْ فَقَالَ ٱلْكَٰفِرُونَ هَٰذَا شَىْءٌ عَجِيبٌ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4633,
      "ayahNumberInSurah": 3,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا ۖ ذَٰلِكَ رَجْعٌۢ بَعِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4634,
      "ayahNumberInSurah": 4,
      "text": "قَدْ عَلِمْنَا مَا تَنقُصُ ٱلْأَرْضُ مِنْهُمْ ۖ وَعِندَنَا كِتَٰبٌ حَفِيظٌۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4635,
      "ayahNumberInSurah": 5,
      "text": "بَلْ كَذَّبُوا۟ بِٱلْحَقِّ لَمَّا جَآءَهُمْ فَهُمْ فِىٓ أَمْرٍۢ مَّرِيجٍ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4636,
      "ayahNumberInSurah": 6,
      "text": "أَفَلَمْ يَنظُرُوٓا۟ إِلَى ٱلسَّمَآءِ فَوْقَهُمْ كَيْفَ بَنَيْنَٰهَا وَزَيَّنَّٰهَا وَمَا لَهَا مِن فُرُوجٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4637,
      "ayahNumberInSurah": 7,
      "text": "وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ زَوْجٍۭ بَهِيجٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4638,
      "ayahNumberInSurah": 8,
      "text": "تَبْصِرَةًۭ وَذِكْرَىٰ لِكُلِّ عَبْدٍۢ مُّنِيبٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4639,
      "ayahNumberInSurah": 9,
      "text": "وَنَزَّلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ مُّبَٰرَكًۭا فَأَنۢبَتْنَا بِهِۦ جَنَّٰتٍۢ وَحَبَّ ٱلْحَصِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4640,
      "ayahNumberInSurah": 10,
      "text": "وَٱلنَّخْلَ بَاسِقَٰتٍۢ لَّهَا طَلْعٌۭ نَّضِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4641,
      "ayahNumberInSurah": 11,
      "text": "رِّزْقًۭا لِّلْعِبَادِ ۖ وَأَحْيَيْنَا بِهِۦ بَلْدَةًۭ مَّيْتًۭا ۚ كَذَٰلِكَ ٱلْخُرُوجُ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4642,
      "ayahNumberInSurah": 12,
      "text": "كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ وَأَصْحَٰبُ ٱلرَّسِّ وَثَمُودُ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4643,
      "ayahNumberInSurah": 13,
      "text": "وَعَادٌۭ وَفِرْعَوْنُ وَإِخْوَٰنُ لُوطٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4644,
      "ayahNumberInSurah": 14,
      "text": "وَأَصْحَٰبُ ٱلْأَيْكَةِ وَقَوْمُ تُبَّعٍۢ ۚ كُلٌّۭ كَذَّبَ ٱلرُّسُلَ فَحَقَّ وَعِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4645,
      "ayahNumberInSurah": 15,
      "text": "أَفَعَيِينَا بِٱلْخَلْقِ ٱلْأَوَّلِ ۚ بَلْ هُمْ فِى لَبْسٍۢ مِّنْ خَلْقٍۢ جَدِيدٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 518,
      "ruku": 452,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4646,
      "ayahNumberInSurah": 16,
      "text": "وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ وَنَعْلَمُ مَا تُوَسْوِسُ بِهِۦ نَفْسُهُۥ ۖ وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنْ حَبْلِ ٱلْوَرِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4647,
      "ayahNumberInSurah": 17,
      "text": "إِذْ يَتَلَقَّى ٱلْمُتَلَقِّيَانِ عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ قَعِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4648,
      "ayahNumberInSurah": 18,
      "text": "مَّا يَلْفِظُ مِن قَوْلٍ إِلَّا لَدَيْهِ رَقِيبٌ عَتِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4649,
      "ayahNumberInSurah": 19,
      "text": "وَجَآءَتْ سَكْرَةُ ٱلْمَوْتِ بِٱلْحَقِّ ۖ ذَٰلِكَ مَا كُنتَ مِنْهُ تَحِيدُ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4650,
      "ayahNumberInSurah": 20,
      "text": "وَنُفِخَ فِى ٱلصُّورِ ۚ ذَٰلِكَ يَوْمُ ٱلْوَعِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4651,
      "ayahNumberInSurah": 21,
      "text": "وَجَآءَتْ كُلُّ نَفْسٍۢ مَّعَهَا سَآئِقٌۭ وَشَهِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4652,
      "ayahNumberInSurah": 22,
      "text": "لَّقَدْ كُنتَ فِى غَفْلَةٍۢ مِّنْ هَٰذَا فَكَشَفْنَا عَنكَ غِطَآءَكَ فَبَصَرُكَ ٱلْيَوْمَ حَدِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4653,
      "ayahNumberInSurah": 23,
      "text": "وَقَالَ قَرِينُهُۥ هَٰذَا مَا لَدَىَّ عَتِيدٌ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4654,
      "ayahNumberInSurah": 24,
      "text": "أَلْقِيَا فِى جَهَنَّمَ كُلَّ كَفَّارٍ عَنِيدٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4655,
      "ayahNumberInSurah": 25,
      "text": "مَّنَّاعٍۢ لِّلْخَيْرِ مُعْتَدٍۢ مُّرِيبٍ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4656,
      "ayahNumberInSurah": 26,
      "text": "ٱلَّذِى جَعَلَ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَأَلْقِيَاهُ فِى ٱلْعَذَابِ ٱلشَّدِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 207,
      "sajda": false
    },
    {
      "ayahNumber": 4657,
      "ayahNumberInSurah": 27,
      "text": "۞ قَالَ قَرِينُهُۥ رَبَّنَا مَآ أَطْغَيْتُهُۥ وَلَٰكِن كَانَ فِى ضَلَٰلٍۭ بَعِيدٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4658,
      "ayahNumberInSurah": 28,
      "text": "قَالَ لَا تَخْتَصِمُوا۟ لَدَىَّ وَقَدْ قَدَّمْتُ إِلَيْكُم بِٱلْوَعِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4659,
      "ayahNumberInSurah": 29,
      "text": "مَا يُبَدَّلُ ٱلْقَوْلُ لَدَىَّ وَمَآ أَنَا۠ بِظَلَّٰمٍۢ لِّلْعَبِيدِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 453,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4660,
      "ayahNumberInSurah": 30,
      "text": "يَوْمَ نَقُولُ لِجَهَنَّمَ هَلِ ٱمْتَلَأْتِ وَتَقُولُ هَلْ مِن مَّزِيدٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4661,
      "ayahNumberInSurah": 31,
      "text": "وَأُزْلِفَتِ ٱلْجَنَّةُ لِلْمُتَّقِينَ غَيْرَ بَعِيدٍ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4662,
      "ayahNumberInSurah": 32,
      "text": "هَٰذَا مَا تُوعَدُونَ لِكُلِّ أَوَّابٍ حَفِيظٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4663,
      "ayahNumberInSurah": 33,
      "text": "مَّنْ خَشِىَ ٱلرَّحْمَٰنَ بِٱلْغَيْبِ وَجَآءَ بِقَلْبٍۢ مُّنِيبٍ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4664,
      "ayahNumberInSurah": 34,
      "text": "ٱدْخُلُوهَا بِسَلَٰمٍۢ ۖ ذَٰلِكَ يَوْمُ ٱلْخُلُودِ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4665,
      "ayahNumberInSurah": 35,
      "text": "لَهُم مَّا يَشَآءُونَ فِيهَا وَلَدَيْنَا مَزِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 519,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4666,
      "ayahNumberInSurah": 36,
      "text": "وَكَمْ أَهْلَكْنَا قَبْلَهُم مِّن قَرْنٍ هُمْ أَشَدُّ مِنْهُم بَطْشًۭا فَنَقَّبُوا۟ فِى ٱلْبِلَٰدِ هَلْ مِن مَّحِيصٍ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4667,
      "ayahNumberInSurah": 37,
      "text": "إِنَّ فِى ذَٰلِكَ لَذِكْرَىٰ لِمَن كَانَ لَهُۥ قَلْبٌ أَوْ أَلْقَى ٱلسَّمْعَ وَهُوَ شَهِيدٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4668,
      "ayahNumberInSurah": 38,
      "text": "وَلَقَدْ خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا فِى سِتَّةِ أَيَّامٍۢ وَمَا مَسَّنَا مِن لُّغُوبٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4669,
      "ayahNumberInSurah": 39,
      "text": "فَٱصْبِرْ عَلَىٰ مَا يَقُولُونَ وَسَبِّحْ بِحَمْدِ رَبِّكَ قَبْلَ طُلُوعِ ٱلشَّمْسِ وَقَبْلَ ٱلْغُرُوبِ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4670,
      "ayahNumberInSurah": 40,
      "text": "وَمِنَ ٱلَّيْلِ فَسَبِّحْهُ وَأَدْبَٰرَ ٱلسُّجُودِ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4671,
      "ayahNumberInSurah": 41,
      "text": "وَٱسْتَمِعْ يَوْمَ يُنَادِ ٱلْمُنَادِ مِن مَّكَانٍۢ قَرِيبٍۢ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4672,
      "ayahNumberInSurah": 42,
      "text": "يَوْمَ يَسْمَعُونَ ٱلصَّيْحَةَ بِٱلْحَقِّ ۚ ذَٰلِكَ يَوْمُ ٱلْخُرُوجِ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4673,
      "ayahNumberInSurah": 43,
      "text": "إِنَّا نَحْنُ نُحْىِۦ وَنُمِيتُ وَإِلَيْنَا ٱلْمَصِيرُ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
      "ayahNumber": 4674,
      "ayahNumberInSurah": 44,
      "text": "يَوْمَ تَشَقَّقُ ٱلْأَرْضُ عَنْهُمْ سِرَاعًۭا ۚ ذَٰلِكَ حَشْرٌ عَلَيْنَا يَسِيرٌۭ",
      "juz": 26,
      "manzil": 7,
      "page": 520,
      "ruku": 454,
      "hizbQuarter": 208,
      "sajda": false
    },
    {
