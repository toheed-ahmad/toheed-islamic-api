{
  "metadata": {
    "surahNumber": 56,
    "surahNameArabic": "سُورَةُ الوَاقِعَةِ",
    "surahNameEnglish": "Al-Waaqia",
    "surahNameTranslation": "The Inevitable",
    "revelationType": "Meccan",
    "numberOfAyahs": 96
  },
  "ayahs": [
    {
      "ayahNumber": 4980,
      "ayahNumberInSurah": 1,
      "text": " إِذَا وَقَعَتِ ٱلْوَاقِعَةُ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4981,
      "ayahNumberInSurah": 2,
      "text": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4982,
      "ayahNumberInSurah": 3,
      "text": "خَافِضَةٌۭ رَّافِعَةٌ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4983,
      "ayahNumberInSurah": 4,
      "text": "إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّۭا",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4984,
      "ayahNumberInSurah": 5,
      "text": "وَبُسَّتِ ٱلْجِبَالُ بَسًّۭا",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4985,
      "ayahNumberInSurah": 6,
      "text": "فَكَانَتْ هَبَآءًۭ مُّنۢبَثًّۭا",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4986,
      "ayahNumberInSurah": 7,
      "text": "وَكُنتُمْ أَزْوَٰجًۭا ثَلَٰثَةًۭ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4987,
      "ayahNumberInSurah": 8,
      "text": "فَأَصْحَٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَٰبُ ٱلْمَيْمَنَةِ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4988,
      "ayahNumberInSurah": 9,
      "text": "وَأَصْحَٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَٰبُ ٱلْمَشْـَٔمَةِ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4989,
      "ayahNumberInSurah": 10,
      "text": "وَٱلسَّٰبِقُونَ ٱلسَّٰبِقُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4990,
      "ayahNumberInSurah": 11,
      "text": "أُو۟لَٰٓئِكَ ٱلْمُقَرَّبُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4991,
      "ayahNumberInSurah": 12,
      "text": "فِى جَنَّٰتِ ٱلنَّعِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4992,
      "ayahNumberInSurah": 13,
      "text": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4993,
      "ayahNumberInSurah": 14,
      "text": "وَقَلِيلٌۭ مِّنَ ٱلْءَاخِرِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4994,
      "ayahNumberInSurah": 15,
      "text": "عَلَىٰ سُرُرٍۢ مَّوْضُونَةٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4995,
      "ayahNumberInSurah": 16,
      "text": "مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَٰبِلِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 534,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4996,
      "ayahNumberInSurah": 17,
      "text": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌۭ مُّخَلَّدُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4997,
      "ayahNumberInSurah": 18,
      "text": "بِأَكْوَابٍۢ وَأَبَارِيقَ وَكَأْسٍۢ مِّن مَّعِينٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4998,
      "ayahNumberInSurah": 19,
      "text": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 4999,
      "ayahNumberInSurah": 20,
      "text": "وَفَٰكِهَةٍۢ مِّمَّا يَتَخَيَّرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5000,
      "ayahNumberInSurah": 21,
      "text": "وَلَحْمِ طَيْرٍۢ مِّمَّا يَشْتَهُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5001,
      "ayahNumberInSurah": 22,
      "text": "وَحُورٌ عِينٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5002,
      "ayahNumberInSurah": 23,
      "text": "كَأَمْثَٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5003,
      "ayahNumberInSurah": 24,
      "text": "جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5004,
      "ayahNumberInSurah": 25,
      "text": "لَا يَسْمَعُونَ فِيهَا لَغْوًۭا وَلَا تَأْثِيمًا",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5005,
      "ayahNumberInSurah": 26,
      "text": "إِلَّا قِيلًۭا سَلَٰمًۭا سَلَٰمًۭا",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5006,
      "ayahNumberInSurah": 27,
      "text": "وَأَصْحَٰبُ ٱلْيَمِينِ مَآ أَصْحَٰبُ ٱلْيَمِينِ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5007,
      "ayahNumberInSurah": 28,
      "text": "فِى سِدْرٍۢ مَّخْضُودٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5008,
      "ayahNumberInSurah": 29,
      "text": "وَطَلْحٍۢ مَّنضُودٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5009,
      "ayahNumberInSurah": 30,
      "text": "وَظِلٍّۢ مَّمْدُودٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5010,
      "ayahNumberInSurah": 31,
      "text": "وَمَآءٍۢ مَّسْكُوبٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5011,
      "ayahNumberInSurah": 32,
      "text": "وَفَٰكِهَةٍۢ كَثِيرَةٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5012,
      "ayahNumberInSurah": 33,
      "text": "لَّا مَقْطُوعَةٍۢ وَلَا مَمْنُوعَةٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5013,
      "ayahNumberInSurah": 34,
      "text": "وَفُرُشٍۢ مَّرْفُوعَةٍ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5014,
      "ayahNumberInSurah": 35,
      "text": "إِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءًۭ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5015,
      "ayahNumberInSurah": 36,
      "text": "فَجَعَلْنَٰهُنَّ أَبْكَارًا",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5016,
      "ayahNumberInSurah": 37,
      "text": "عُرُبًا أَتْرَابًۭا",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5017,
      "ayahNumberInSurah": 38,
      "text": "لِّأَصْحَٰبِ ٱلْيَمِينِ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 469,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5018,
      "ayahNumberInSurah": 39,
      "text": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5019,
      "ayahNumberInSurah": 40,
      "text": "وَثُلَّةٌۭ مِّنَ ٱلْءَاخِرِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5020,
      "ayahNumberInSurah": 41,
      "text": "وَأَصْحَٰبُ ٱلشِّمَالِ مَآ أَصْحَٰبُ ٱلشِّمَالِ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5021,
      "ayahNumberInSurah": 42,
      "text": "فِى سَمُومٍۢ وَحَمِيمٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5022,
      "ayahNumberInSurah": 43,
      "text": "وَظِلٍّۢ مِّن يَحْمُومٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5023,
      "ayahNumberInSurah": 44,
      "text": "لَّا بَارِدٍۢ وَلَا كَرِيمٍ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5024,
      "ayahNumberInSurah": 45,
      "text": "إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5025,
      "ayahNumberInSurah": 46,
      "text": "وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5026,
      "ayahNumberInSurah": 47,
      "text": "وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5027,
      "ayahNumberInSurah": 48,
      "text": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5028,
      "ayahNumberInSurah": 49,
      "text": "قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْءَاخِرِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5029,
      "ayahNumberInSurah": 50,
      "text": "لَمَجْمُوعُونَ إِلَىٰ مِيقَٰتِ يَوْمٍۢ مَّعْلُومٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 535,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5030,
      "ayahNumberInSurah": 51,
      "text": "ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5031,
      "ayahNumberInSurah": 52,
      "text": "لَءَاكِلُونَ مِن شَجَرٍۢ مِّن زَقُّومٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5032,
      "ayahNumberInSurah": 53,
      "text": "فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5033,
      "ayahNumberInSurah": 54,
      "text": "فَشَٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5034,
      "ayahNumberInSurah": 55,
      "text": "فَشَٰرِبُونَ شُرْبَ ٱلْهِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5035,
      "ayahNumberInSurah": 56,
      "text": "هَٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5036,
      "ayahNumberInSurah": 57,
      "text": "نَحْنُ خَلَقْنَٰكُمْ فَلَوْلَا تُصَدِّقُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5037,
      "ayahNumberInSurah": 58,
      "text": "أَفَرَءَيْتُم مَّا تُمْنُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5038,
      "ayahNumberInSurah": 59,
      "text": "ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَٰلِقُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5039,
      "ayahNumberInSurah": 60,
      "text": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5040,
      "ayahNumberInSurah": 61,
      "text": "عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5041,
      "ayahNumberInSurah": 62,
      "text": "وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5042,
      "ayahNumberInSurah": 63,
      "text": "أَفَرَءَيْتُم مَّا تَحْرُثُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5043,
      "ayahNumberInSurah": 64,
      "text": "ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5044,
      "ayahNumberInSurah": 65,
      "text": "لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰمًۭا فَظَلْتُمْ تَفَكَّهُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5045,
      "ayahNumberInSurah": 66,
      "text": "إِنَّا لَمُغْرَمُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5046,
      "ayahNumberInSurah": 67,
      "text": "بَلْ نَحْنُ مَحْرُومُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5047,
      "ayahNumberInSurah": 68,
      "text": "أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5048,
      "ayahNumberInSurah": 69,
      "text": "ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5049,
      "ayahNumberInSurah": 70,
      "text": "لَوْ نَشَآءُ جَعَلْنَٰهُ أُجَاجًۭا فَلَوْلَا تَشْكُرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5050,
      "ayahNumberInSurah": 71,
      "text": "أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5051,
      "ayahNumberInSurah": 72,
      "text": "ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5052,
      "ayahNumberInSurah": 73,
      "text": "نَحْنُ جَعَلْنَٰهَا تَذْكِرَةًۭ وَمَتَٰعًۭا لِّلْمُقْوِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5053,
      "ayahNumberInSurah": 74,
      "text": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 470,
      "hizbQuarter": 214,
      "sajda": false
    },
    {
      "ayahNumber": 5054,
      "ayahNumberInSurah": 75,
      "text": "۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5055,
      "ayahNumberInSurah": 76,
      "text": "وَإِنَّهُۥ لَقَسَمٌۭ لَّوْ تَعْلَمُونَ عَظِيمٌ",
      "juz": 27,
      "manzil": 7,
      "page": 536,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5056,
      "ayahNumberInSurah": 77,
      "text": "إِنَّهُۥ لَقُرْءَانٌۭ كَرِيمٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5057,
      "ayahNumberInSurah": 78,
      "text": "فِى كِتَٰبٍۢ مَّكْنُونٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5058,
      "ayahNumberInSurah": 79,
      "text": "لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5059,
      "ayahNumberInSurah": 80,
      "text": "تَنزِيلٌۭ مِّن رَّبِّ ٱلْعَٰلَمِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5060,
      "ayahNumberInSurah": 81,
      "text": "أَفَبِهَٰذَا ٱلْحَدِيثِ أَنتُم مُّدْهِنُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5061,
      "ayahNumberInSurah": 82,
      "text": "وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5062,
      "ayahNumberInSurah": 83,
      "text": "فَلَوْلَآ إِذَا بَلَغَتِ ٱلْحُلْقُومَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5063,
      "ayahNumberInSurah": 84,
      "text": "وَأَنتُمْ حِينَئِذٍۢ تَنظُرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5064,
      "ayahNumberInSurah": 85,
      "text": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَٰكِن لَّا تُبْصِرُونَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5065,
      "ayahNumberInSurah": 86,
      "text": "فَلَوْلَآ إِن كُنتُمْ غَيْرَ مَدِينِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5066,
      "ayahNumberInSurah": 87,
      "text": "تَرْجِعُونَهَآ إِن كُنتُمْ صَٰدِقِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5067,
      "ayahNumberInSurah": 88,
      "text": "فَأَمَّآ إِن كَانَ مِنَ ٱلْمُقَرَّبِينَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5068,
      "ayahNumberInSurah": 89,
      "text": "فَرَوْحٌۭ وَرَيْحَانٌۭ وَجَنَّتُ نَعِيمٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5069,
      "ayahNumberInSurah": 90,
      "text": "وَأَمَّآ إِن كَانَ مِنْ أَصْحَٰبِ ٱلْيَمِينِ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5070,
      "ayahNumberInSurah": 91,
      "text": "فَسَلَٰمٌۭ لَّكَ مِنْ أَصْحَٰبِ ٱلْيَمِينِ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5071,
      "ayahNumberInSurah": 92,
      "text": "وَأَمَّآ إِن كَانَ مِنَ ٱلْمُكَذِّبِينَ ٱلضَّآلِّينَ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5072,
      "ayahNumberInSurah": 93,
      "text": "فَنُزُلٌۭ مِّنْ حَمِيمٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5073,
      "ayahNumberInSurah": 94,
      "text": "وَتَصْلِيَةُ جَحِيمٍ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5074,
      "ayahNumberInSurah": 95,
      "text": "إِنَّ هَٰذَا لَهُوَ حَقُّ ٱلْيَقِينِ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    },
    {
      "ayahNumber": 5075,
      "ayahNumberInSurah": 96,
      "text": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ",
      "juz": 27,
      "manzil": 7,
      "page": 537,
      "ruku": 471,
      "hizbQuarter": 215,
      "sajda": false
    }
  ]
}