      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5948,
      "ayahNumberInSurah": 17,
      "text": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
