  "ayahs": [
    {
      "ayahNumber": 5932,
      "ayahNumberInSurah": 1,
      "text": "وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5933,
      "ayahNumberInSurah": 2,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5934,
      "ayahNumberInSurah": 3,
      "text": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5935,
      "ayahNumberInSurah": 4,
      "text": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5936,
      "ayahNumberInSurah": 5,
      "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5937,
      "ayahNumberInSurah": 6,
      "text": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5938,
      "ayahNumberInSurah": 7,
      "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5939,
      "ayahNumberInSurah": 8,
      "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5940,
      "ayahNumberInSurah": 9,
      "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5941,
      "ayahNumberInSurah": 10,
      "text": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5942,
      "ayahNumberInSurah": 11,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5943,
      "ayahNumberInSurah": 12,
      "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5944,
      "ayahNumberInSurah": 13,
      "text": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5945,
      "ayahNumberInSurah": 14,
      "text": "وَمَا هُوَ بِٱلْهَزْلِ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5946,
      "ayahNumberInSurah": 15,
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 528,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5947,
      "ayahNumberInSurah": 16,
      "text": "وَأَكِيدُ كَيْدًۭا",
      "juz": 30,
