      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5802,
      "ayahNumberInSurah": 2,
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5803,
      "ayahNumberInSurah": 3,
      "text": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5804,
      "ayahNumberInSurah": 4,
      "text": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5805,
      "ayahNumberInSurah": 5,
      "text": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5806,
      "ayahNumberInSurah": 6,
      "text": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5807,
      "ayahNumberInSurah": 7,
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5808,
      "ayahNumberInSurah": 8,
      "text": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5809,
      "ayahNumberInSurah": 9,
      "text": "بِأَىِّ ذَنۢبٍۢ قُتِلَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5810,
      "ayahNumberInSurah": 10,
      "text": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5811,
      "ayahNumberInSurah": 11,
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5812,
      "ayahNumberInSurah": 12,
      "text": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5813,
      "ayahNumberInSurah": 13,
      "text": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5814,
      "ayahNumberInSurah": 14,
      "text": "عَلِمَتْ نَفْسٌۭ مَّآ أَحْضَرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5815,
      "ayahNumberInSurah": 15,
      "text": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5816,
      "ayahNumberInSurah": 16,
      "text": "ٱلْجَوَارِ ٱلْكُنَّسِ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5817,
      "ayahNumberInSurah": 17,
      "text": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5818,
      "ayahNumberInSurah": 18,
      "text": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5819,
      "ayahNumberInSurah": 19,
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5820,
      "ayahNumberInSurah": 20,
      "text": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5821,
      "ayahNumberInSurah": 21,
      "text": "مُّطَاعٍۢ ثَمَّ أَمِينٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5822,
      "ayahNumberInSurah": 22,
      "text": "وَمَا صَاحِبُكُم بِمَجْنُونٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5823,
      "ayahNumberInSurah": 23,
      "text": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5824,
      "ayahNumberInSurah": 24,
      "text": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5825,
      "ayahNumberInSurah": 25,
      "text": "وَمَا هُوَ بِقَوْلِ شَيْطَٰنٍۢ رَّجِيمٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5826,
      "ayahNumberInSurah": 26,
      "text": "فَأَيْنَ تَذْهَبُونَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5827,
      "ayahNumberInSurah": 27,
      "text": "إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5828,
      "ayahNumberInSurah": 28,
      "text": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5829,
      "ayahNumberInSurah": 29,
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ",
      "juz": 30,
      "manzil": 7,
      "page": 586,
      "ruku": 523,
