      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5891,
      "ayahNumberInSurah": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ",
      "juz": 30,
      "manzil": 7,
