      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5894,
      "ayahNumberInSurah": 10,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ",
