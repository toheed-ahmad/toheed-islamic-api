      "ruku": 526,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5892,
      "ayahNumberInSurah": 8,
      "text": "فَسَوْفَ يُحَاسَبُ حِسَابًۭا يَسِيرًۭا",
