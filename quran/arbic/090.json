      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6034,
      "ayahNumberInSurah": 11,
      "text": "فَلَا ٱقْتَحَمَ ٱلْعَقَبَةَ",
