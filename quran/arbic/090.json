  "ayahs": [
    {
      "ayahNumber": 6024,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِهَٰذَا ٱلْبَلَدِ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6025,
      "ayahNumberInSurah": 2,
      "text": "وَأَنتَ حِلٌّۢ بِهَٰذَا ٱلْبَلَدِ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6026,
      "ayahNumberInSurah": 3,
      "text": "وَوَالِدٍۢ وَمَا وَلَدَ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6027,
      "ayahNumberInSurah": 4,
      "text": "لَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ فِى كَبَدٍ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6028,
      "ayahNumberInSurah": 5,
      "text": "أَيَحْسَبُ أَن لَّن يَقْدِرَ عَلَيْهِ أَحَدٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6029,
      "ayahNumberInSurah": 6,
      "text": "يَقُولُ أَهْلَكْتُ مَالًۭا لُّبَدًا",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6030,
      "ayahNumberInSurah": 7,
      "text": "أَيَحْسَبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6031,
      "ayahNumberInSurah": 8,
      "text": "أَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ",
      "juz": 30,
      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6032,
      "ayahNumberInSurah": 9,
      "text": "وَلِسَانًۭا وَشَفَتَيْنِ",
