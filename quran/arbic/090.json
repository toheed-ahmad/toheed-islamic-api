      "manzil": 7,
      "page": 594,
      "ruku": 532,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6033,
      "ayahNumberInSurah": 10,
      "text": "وَهَدَيْنَٰهُ ٱلنَّجْدَيْنِ",
