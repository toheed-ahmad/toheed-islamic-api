{
  "metadata": {
    "surahNumber": 80,
    "surahNameArabic": "سُورَةُ عَبَسَ",
    "surahNameEnglish": "Abasa",
    "surahNameTranslation": "He frowned",
    "revelationType": "Meccan",
    "numberOfAyahs": 42
  },
  "ayahs": [
    {
      "ayahNumber": 5759,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5760,
      "ayahNumberInSurah": 2,
      "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5761,
      "ayahNumberInSurah": 3,
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5762,
      "ayahNumberInSurah": 4,
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5763,
      "ayahNumberInSurah": 5,
      "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5764,
      "ayahNumberInSurah": 6,
      "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5765,
      "ayahNumberInSurah": 7,
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5766,
      "ayahNumberInSurah": 8,
      "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5767,
      "ayahNumberInSurah": 9,
      "text": "وَهُوَ يَخْشَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5768,
      "ayahNumberInSurah": 10,
      "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5769,
      "ayahNumberInSurah": 11,
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5770,
      "ayahNumberInSurah": 12,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5771,
      "ayahNumberInSurah": 13,
      "text": "فِى صُحُفٍۢ مُّكَرَّمَةٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5772,
      "ayahNumberInSurah": 14,
      "text": "مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5773,
      "ayahNumberInSurah": 15,
      "text": "بِأَيْدِى سَفَرَةٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5774,
      "ayahNumberInSurah": 16,
      "text": "كِرَامٍۭ بَرَرَةٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5775,
      "ayahNumberInSurah": 17,
      "text": "قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5776,
      "ayahNumberInSurah": 18,
      "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5777,
      "ayahNumberInSurah": 19,
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5778,
      "ayahNumberInSurah": 20,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5779,
      "ayahNumberInSurah": 21,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5780,
      "ayahNumberInSurah": 22,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5781,
      "ayahNumberInSurah": 23,
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5782,
      "ayahNumberInSurah": 24,
      "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5783,
      "ayahNumberInSurah": 25,
      "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5784,
      "ayahNumberInSurah": 26,
      "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5785,
      "ayahNumberInSurah": 27,
      "text": "فَأَنۢبَتْنَا فِيهَا حَبًّۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5786,
      "ayahNumberInSurah": 28,
      "text": "وَعِنَبًۭا وَقَضْبًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5787,
      "ayahNumberInSurah": 29,
      "text": "وَزَيْتُونًۭا وَنَخْلًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5788,
      "ayahNumberInSurah": 30,
      "text": "وَحَدَآئِقَ غُلْبًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5789,
      "ayahNumberInSurah": 31,
      "text": "وَفَٰكِهَةًۭ وَأَبًّۭا",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5790,
      "ayahNumberInSurah": 32,
      "text": "مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5791,
      "ayahNumberInSurah": 33,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5792,
      "ayahNumberInSurah": 34,
      "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5793,
      "ayahNumberInSurah": 35,
      "text": "وَأُمِّهِۦ وَأَبِيهِ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5794,
      "ayahNumberInSurah": 36,
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5795,
      "ayahNumberInSurah": 37,
      "text": "لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5796,
      "ayahNumberInSurah": 38,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5797,
      "ayahNumberInSurah": 39,
      "text": "ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5798,
      "ayahNumberInSurah": 40,
      "text": "وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5799,
      "ayahNumberInSurah": 41,
      "text": "تَرْهَقُهَا قَتَرَةٌ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    },
    {
      "ayahNumber": 5800,
      "ayahNumberInSurah": 42,
      "text": "أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
      "juz": 30,
      "manzil": 7,
      "page": 585,
      "ruku": 522,
      "hizbQuarter": 234,
      "sajda": false
    }
  ]
}