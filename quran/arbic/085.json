  "ayahs": [
    {
      "ayahNumber": 5910,
      "ayahNumberInSurah": 1,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5911,
      "ayahNumberInSurah": 2,
      "text": "وَٱلْيَوْمِ ٱلْمَوْعُودِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5912,
      "ayahNumberInSurah": 3,
      "text": "وَشَاهِدٍۢ وَمَشْهُودٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5913,
      "ayahNumberInSurah": 4,
      "text": "قُتِلَ أَصْحَٰبُ ٱلْأُخْدُودِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5914,
      "ayahNumberInSurah": 5,
      "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5915,
      "ayahNumberInSurah": 6,
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5916,
      "ayahNumberInSurah": 7,
      "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5917,
      "ayahNumberInSurah": 8,
      "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5918,
      "ayahNumberInSurah": 9,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5919,
      "ayahNumberInSurah": 10,
      "text": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5920,
      "ayahNumberInSurah": 11,
      "text": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5921,
      "ayahNumberInSurah": 12,
      "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5922,
      "ayahNumberInSurah": 13,
      "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5923,
      "ayahNumberInSurah": 14,
      "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5924,
      "ayahNumberInSurah": 15,
      "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5925,
      "ayahNumberInSurah": 16,
      "text": "فَعَّالٌۭ لِّمَا يُرِيدُ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5926,
      "ayahNumberInSurah": 17,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5927,
      "ayahNumberInSurah": 18,
      "text": "فِرْعَوْنَ وَثَمُودَ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5928,
      "ayahNumberInSurah": 19,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 590,
      "ruku": 527,
      "hizbQuarter": 236,
      "sajda": false
    },
    {
      "ayahNumber": 5929,
      "ayahNumberInSurah": 20,
      "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ",
      "juz": 30,
      "manzil": 7,
