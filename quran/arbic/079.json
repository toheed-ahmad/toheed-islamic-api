  "ayahs": [
    {
      "ayahNumber": 5713,
      "ayahNumberInSurah": 1,
      "text": " وَٱلنَّٰزِعَٰتِ غَرْقًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5714,
      "ayahNumberInSurah": 2,
      "text": "وَٱلنَّٰشِطَٰتِ نَشْطًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5715,
      "ayahNumberInSurah": 3,
      "text": "وَٱلسَّٰبِحَٰتِ سَبْحًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5716,
      "ayahNumberInSurah": 4,
      "text": "فَٱلسَّٰبِقَٰتِ سَبْقًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5717,
      "ayahNumberInSurah": 5,
      "text": "فَٱلْمُدَبِّرَٰتِ أَمْرًۭا",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5718,
      "ayahNumberInSurah": 6,
      "text": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5719,
      "ayahNumberInSurah": 7,
      "text": "تَتْبَعُهَا ٱلرَّادِفَةُ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5720,
      "ayahNumberInSurah": 8,
      "text": "قُلُوبٌۭ يَوْمَئِذٍۢ وَاجِفَةٌ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5721,
      "ayahNumberInSurah": 9,
      "text": "أَبْصَٰرُهَا خَٰشِعَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5722,
      "ayahNumberInSurah": 10,
      "text": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5723,
      "ayahNumberInSurah": 11,
      "text": "أَءِذَا كُنَّا عِظَٰمًۭا نَّخِرَةًۭ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5724,
      "ayahNumberInSurah": 12,
      "text": "قَالُوا۟ تِلْكَ إِذًۭا كَرَّةٌ خَاسِرَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5725,
      "ayahNumberInSurah": 13,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌۭ وَٰحِدَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5726,
      "ayahNumberInSurah": 14,
      "text": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5727,
      "ayahNumberInSurah": 15,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 583,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5728,
      "ayahNumberInSurah": 16,
      "text": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5729,
      "ayahNumberInSurah": 17,
      "text": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5730,
      "ayahNumberInSurah": 18,
      "text": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5731,
      "ayahNumberInSurah": 19,
      "text": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5732,
      "ayahNumberInSurah": 20,
      "text": "فَأَرَىٰهُ ٱلْءَايَةَ ٱلْكُبْرَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5733,
      "ayahNumberInSurah": 21,
      "text": "فَكَذَّبَ وَعَصَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5734,
      "ayahNumberInSurah": 22,
      "text": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5735,
      "ayahNumberInSurah": 23,
      "text": "فَحَشَرَ فَنَادَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5736,
      "ayahNumberInSurah": 24,
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5737,
      "ayahNumberInSurah": 25,
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْءَاخِرَةِ وَٱلْأُولَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5738,
      "ayahNumberInSurah": 26,
      "text": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةًۭ لِّمَن يَخْشَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 520,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5739,
      "ayahNumberInSurah": 27,
      "text": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5740,
      "ayahNumberInSurah": 28,
      "text": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5741,
      "ayahNumberInSurah": 29,
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5742,
      "ayahNumberInSurah": 30,
      "text": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5743,
      "ayahNumberInSurah": 31,
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5744,
      "ayahNumberInSurah": 32,
      "text": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5745,
      "ayahNumberInSurah": 33,
      "text": "مَتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5746,
      "ayahNumberInSurah": 34,
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5747,
      "ayahNumberInSurah": 35,
      "text": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَٰنُ مَا سَعَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5748,
      "ayahNumberInSurah": 36,
      "text": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5749,
      "ayahNumberInSurah": 37,
      "text": "فَأَمَّا مَن طَغَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5750,
      "ayahNumberInSurah": 38,
      "text": "وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5751,
      "ayahNumberInSurah": 39,
      "text": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5752,
      "ayahNumberInSurah": 40,
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5753,
      "ayahNumberInSurah": 41,
      "text": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5754,
      "ayahNumberInSurah": 42,
      "text": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5755,
      "ayahNumberInSurah": 43,
      "text": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5756,
      "ayahNumberInSurah": 44,
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5757,
      "ayahNumberInSurah": 45,
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "juz": 30,
      "manzil": 7,
      "page": 584,
      "ruku": 521,
      "hizbQuarter": 233,
      "sajda": false
    },
    {
      "ayahNumber": 5758,
      "ayahNumberInSurah": 46,
      "text": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا",
      "juz": 30,
      "manzil": 7,
