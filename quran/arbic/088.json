  "ayahs": [
    {
      "ayahNumber": 5968,
      "ayahNumberInSurah": 1,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5969,
      "ayahNumberInSurah": 2,
      "text": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5970,
      "ayahNumberInSurah": 3,
      "text": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5971,
      "ayahNumberInSurah": 4,
      "text": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5972,
      "ayahNumberInSurah": 5,
      "text": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5973,
      "ayahNumberInSurah": 6,
      "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5974,
      "ayahNumberInSurah": 7,
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5975,
      "ayahNumberInSurah": 8,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5976,
      "ayahNumberInSurah": 9,
      "text": "لِّسَعْيِهَا رَاضِيَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5977,
      "ayahNumberInSurah": 10,
      "text": "فِى جَنَّةٍ عَالِيَةٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5978,
      "ayahNumberInSurah": 11,
      "text": "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5979,
      "ayahNumberInSurah": 12,
      "text": "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5980,
      "ayahNumberInSurah": 13,
      "text": "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5981,
      "ayahNumberInSurah": 14,
      "text": "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5982,
      "ayahNumberInSurah": 15,
      "text": "وَنَمَارِقُ مَصْفُوفَةٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5983,
      "ayahNumberInSurah": 16,
      "text": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5984,
      "ayahNumberInSurah": 17,
      "text": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5985,
      "ayahNumberInSurah": 18,
      "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5986,
      "ayahNumberInSurah": 19,
      "text": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5987,
      "ayahNumberInSurah": 20,
      "text": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5988,
      "ayahNumberInSurah": 21,
      "text": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5989,
      "ayahNumberInSurah": 22,
      "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5990,
      "ayahNumberInSurah": 23,
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5991,
      "ayahNumberInSurah": 24,
      "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5992,
      "ayahNumberInSurah": 25,
      "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5993,
      "ayahNumberInSurah": 26,
      "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "juz": 30,
      "manzil": 7,
      "page": 592,
      "ruku": 530,
      "hizbQuarter": 237,
