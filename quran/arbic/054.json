{
  "metadata": {
    "surahNumber": 54,
    "surahNameArabic": "سُورَةُ القَمَرِ",
    "surahNameEnglish": "Al-Qamar",
    "surahNameTranslation": "The Moon",
    "revelationType": "Meccan",
    "numberOfAyahs": 55
  },
  "ayahs": [
    {
      "ayahNumber": 4847,
      "ayahNumberInSurah": 1,
      "text": " ٱقْتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلْقَمَرُ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4848,
      "ayahNumberInSurah": 2,
      "text": "وَإِن يَرَوْا۟ ءَايَةًۭ يُعْرِضُوا۟ وَيَقُولُوا۟ سِحْرٌۭ مُّسْتَمِرٌّۭ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4849,
      "ayahNumberInSurah": 3,
      "text": "وَكَذَّبُوا۟ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ ۚ وَكُلُّ أَمْرٍۢ مُّسْتَقِرٌّۭ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4850,
      "ayahNumberInSurah": 4,
      "text": "وَلَقَدْ جَآءَهُم مِّنَ ٱلْأَنۢبَآءِ مَا فِيهِ مُزْدَجَرٌ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4851,
      "ayahNumberInSurah": 5,
      "text": "حِكْمَةٌۢ بَٰلِغَةٌۭ ۖ فَمَا تُغْنِ ٱلنُّذُرُ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4852,
      "ayahNumberInSurah": 6,
      "text": "فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَىْءٍۢ نُّكُرٍ",
      "juz": 27,
      "manzil": 7,
      "page": 528,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4853,
      "ayahNumberInSurah": 7,
      "text": "خُشَّعًا أَبْصَٰرُهُمْ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ كَأَنَّهُمْ جَرَادٌۭ مُّنتَشِرٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4854,
      "ayahNumberInSurah": 8,
      "text": "مُّهْطِعِينَ إِلَى ٱلدَّاعِ ۖ يَقُولُ ٱلْكَٰفِرُونَ هَٰذَا يَوْمٌ عَسِرٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 211,
      "sajda": false
    },
    {
      "ayahNumber": 4855,
      "ayahNumberInSurah": 9,
      "text": "۞ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ فَكَذَّبُوا۟ عَبْدَنَا وَقَالُوا۟ مَجْنُونٌۭ وَٱزْدُجِرَ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4856,
      "ayahNumberInSurah": 10,
      "text": "فَدَعَا رَبَّهُۥٓ أَنِّى مَغْلُوبٌۭ فَٱنتَصِرْ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4857,
      "ayahNumberInSurah": 11,
      "text": "فَفَتَحْنَآ أَبْوَٰبَ ٱلسَّمَآءِ بِمَآءٍۢ مُّنْهَمِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4858,
      "ayahNumberInSurah": 12,
      "text": "وَفَجَّرْنَا ٱلْأَرْضَ عُيُونًۭا فَٱلْتَقَى ٱلْمَآءُ عَلَىٰٓ أَمْرٍۢ قَدْ قُدِرَ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4859,
      "ayahNumberInSurah": 13,
      "text": "وَحَمَلْنَٰهُ عَلَىٰ ذَاتِ أَلْوَٰحٍۢ وَدُسُرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4860,
      "ayahNumberInSurah": 14,
      "text": "تَجْرِى بِأَعْيُنِنَا جَزَآءًۭ لِّمَن كَانَ كُفِرَ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4861,
      "ayahNumberInSurah": 15,
      "text": "وَلَقَد تَّرَكْنَٰهَآ ءَايَةًۭ فَهَلْ مِن مُّدَّكِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4862,
      "ayahNumberInSurah": 16,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4863,
      "ayahNumberInSurah": 17,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4864,
      "ayahNumberInSurah": 18,
      "text": "كَذَّبَتْ عَادٌۭ فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4865,
      "ayahNumberInSurah": 19,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ رِيحًۭا صَرْصَرًۭا فِى يَوْمِ نَحْسٍۢ مُّسْتَمِرٍّۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4866,
      "ayahNumberInSurah": 20,
      "text": "تَنزِعُ ٱلنَّاسَ كَأَنَّهُمْ أَعْجَازُ نَخْلٍۢ مُّنقَعِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4867,
      "ayahNumberInSurah": 21,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4868,
      "ayahNumberInSurah": 22,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 463,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4869,
      "ayahNumberInSurah": 23,
      "text": "كَذَّبَتْ ثَمُودُ بِٱلنُّذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4870,
      "ayahNumberInSurah": 24,
      "text": "فَقَالُوٓا۟ أَبَشَرًۭا مِّنَّا وَٰحِدًۭا نَّتَّبِعُهُۥٓ إِنَّآ إِذًۭا لَّفِى ضَلَٰلٍۢ وَسُعُرٍ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4871,
      "ayahNumberInSurah": 25,
      "text": "أَءُلْقِىَ ٱلذِّكْرُ عَلَيْهِ مِنۢ بَيْنِنَا بَلْ هُوَ كَذَّابٌ أَشِرٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4872,
      "ayahNumberInSurah": 26,
      "text": "سَيَعْلَمُونَ غَدًۭا مَّنِ ٱلْكَذَّابُ ٱلْأَشِرُ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4873,
      "ayahNumberInSurah": 27,
      "text": "إِنَّا مُرْسِلُوا۟ ٱلنَّاقَةِ فِتْنَةًۭ لَّهُمْ فَٱرْتَقِبْهُمْ وَٱصْطَبِرْ",
      "juz": 27,
      "manzil": 7,
      "page": 529,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4874,
      "ayahNumberInSurah": 28,
      "text": "وَنَبِّئْهُمْ أَنَّ ٱلْمَآءَ قِسْمَةٌۢ بَيْنَهُمْ ۖ كُلُّ شِرْبٍۢ مُّحْتَضَرٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4875,
      "ayahNumberInSurah": 29,
      "text": "فَنَادَوْا۟ صَاحِبَهُمْ فَتَعَاطَىٰ فَعَقَرَ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4876,
      "ayahNumberInSurah": 30,
      "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4877,
      "ayahNumberInSurah": 31,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ صَيْحَةًۭ وَٰحِدَةًۭ فَكَانُوا۟ كَهَشِيمِ ٱلْمُحْتَظِرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4878,
      "ayahNumberInSurah": 32,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4879,
      "ayahNumberInSurah": 33,
      "text": "كَذَّبَتْ قَوْمُ لُوطٍۭ بِٱلنُّذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4880,
      "ayahNumberInSurah": 34,
      "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ حَاصِبًا إِلَّآ ءَالَ لُوطٍۢ ۖ نَّجَّيْنَٰهُم بِسَحَرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4881,
      "ayahNumberInSurah": 35,
      "text": "نِّعْمَةًۭ مِّنْ عِندِنَا ۚ كَذَٰلِكَ نَجْزِى مَن شَكَرَ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4882,
      "ayahNumberInSurah": 36,
      "text": "وَلَقَدْ أَنذَرَهُم بَطْشَتَنَا فَتَمَارَوْا۟ بِٱلنُّذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4883,
      "ayahNumberInSurah": 37,
      "text": "وَلَقَدْ رَٰوَدُوهُ عَن ضَيْفِهِۦ فَطَمَسْنَآ أَعْيُنَهُمْ فَذُوقُوا۟ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4884,
      "ayahNumberInSurah": 38,
      "text": "وَلَقَدْ صَبَّحَهُم بُكْرَةً عَذَابٌۭ مُّسْتَقِرٌّۭ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4885,
      "ayahNumberInSurah": 39,
      "text": "فَذُوقُوا۟ عَذَابِى وَنُذُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4886,
      "ayahNumberInSurah": 40,
      "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 464,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4887,
      "ayahNumberInSurah": 41,
      "text": "وَلَقَدْ جَآءَ ءَالَ فِرْعَوْنَ ٱلنُّذُرُ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4888,
      "ayahNumberInSurah": 42,
      "text": "كَذَّبُوا۟ بِـَٔايَٰتِنَا كُلِّهَا فَأَخَذْنَٰهُمْ أَخْذَ عَزِيزٍۢ مُّقْتَدِرٍ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4889,
      "ayahNumberInSurah": 43,
      "text": "أَكُفَّارُكُمْ خَيْرٌۭ مِّنْ أُو۟لَٰٓئِكُمْ أَمْ لَكُم بَرَآءَةٌۭ فِى ٱلزُّبُرِ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4890,
      "ayahNumberInSurah": 44,
      "text": "أَمْ يَقُولُونَ نَحْنُ جَمِيعٌۭ مُّنتَصِرٌۭ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4891,
      "ayahNumberInSurah": 45,
      "text": "سَيُهْزَمُ ٱلْجَمْعُ وَيُوَلُّونَ ٱلدُّبُرَ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4892,
      "ayahNumberInSurah": 46,
      "text": "بَلِ ٱلسَّاعَةُ مَوْعِدُهُمْ وَٱلسَّاعَةُ أَدْهَىٰ وَأَمَرُّ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4893,
      "ayahNumberInSurah": 47,
      "text": "إِنَّ ٱلْمُجْرِمِينَ فِى ضَلَٰلٍۢ وَسُعُرٍۢ",
      "juz": 27,
      "manzil": 7,
      "page": 530,
      "ruku": 465,
      "hizbQuarter": 212,
      "sajda": false
    },
    {
      "ayahNumber": 4894,
      "ayahNumberInSurah": 48,
      "text": "يَوْمَ يُسْحَبُونَ فِى ٱلنَّارِ عَلَىٰ وُجُوهِهِمْ ذُوقُوا۟ مَسَّ سَقَرَ",
      "juz": 27,
      "manzil": 7,
