{
  "metadata": {
    "surahNumber": 68,
    "surahNameArabic": "سُورَةُ القَلَمِ",
    "surahNameEnglish": "Al-Qalam",
    "surahNameTranslation": "The Pen",
    "revelationType": "Meccan",
    "numberOfAyahs": 52
  },
  "ayahs": [
    {
      "ayahNumber": 5272,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ نٓ ۚ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5273,
      "ayahNumberInSurah": 2,
      "text": "مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5274,
      "ayahNumberInSurah": 3,
      "text": "وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5275,
      "ayahNumberInSurah": 4,
      "text": "وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5276,
      "ayahNumberInSurah": 5,
      "text": "فَسَتُبْصِرُ وَيُبْصِرُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5277,
      "ayahNumberInSurah": 6,
      "text": "بِأَييِّكُمُ ٱلْمَفْتُونُ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5278,
      "ayahNumberInSurah": 7,
      "text": "إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5279,
      "ayahNumberInSurah": 8,
      "text": "فَلَا تُطِعِ ٱلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5280,
      "ayahNumberInSurah": 9,
      "text": "وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5281,
      "ayahNumberInSurah": 10,
      "text": "وَلَا تُطِعْ كُلَّ حَلَّافٍۢ مَّهِينٍ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5282,
      "ayahNumberInSurah": 11,
      "text": "هَمَّازٍۢ مَّشَّآءٍۭ بِنَمِيمٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5283,
      "ayahNumberInSurah": 12,
      "text": "مَّنَّاعٍۢ لِّلْخَيْرِ مُعْتَدٍ أَثِيمٍ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5284,
      "ayahNumberInSurah": 13,
      "text": "عُتُلٍّۭ بَعْدَ ذَٰلِكَ زَنِيمٍ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5285,
      "ayahNumberInSurah": 14,
      "text": "أَن كَانَ ذَا مَالٍۢ وَبَنِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5286,
      "ayahNumberInSurah": 15,
      "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 564,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5287,
      "ayahNumberInSurah": 16,
      "text": "سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5288,
      "ayahNumberInSurah": 17,
      "text": "إِنَّا بَلَوْنَٰهُمْ كَمَا بَلَوْنَآ أَصْحَٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5289,
      "ayahNumberInSurah": 18,
      "text": "وَلَا يَسْتَثْنُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5290,
      "ayahNumberInSurah": 19,
      "text": "فَطَافَ عَلَيْهَا طَآئِفٌۭ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5291,
      "ayahNumberInSurah": 20,
      "text": "فَأَصْبَحَتْ كَٱلصَّرِيمِ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5292,
      "ayahNumberInSurah": 21,
      "text": "فَتَنَادَوْا۟ مُصْبِحِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5293,
      "ayahNumberInSurah": 22,
      "text": "أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَٰرِمِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5294,
      "ayahNumberInSurah": 23,
      "text": "فَٱنطَلَقُوا۟ وَهُمْ يَتَخَٰفَتُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5295,
      "ayahNumberInSurah": 24,
      "text": "أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِّسْكِينٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5296,
      "ayahNumberInSurah": 25,
      "text": "وَغَدَوْا۟ عَلَىٰ حَرْدٍۢ قَٰدِرِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5297,
      "ayahNumberInSurah": 26,
      "text": "فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5298,
      "ayahNumberInSurah": 27,
      "text": "بَلْ نَحْنُ مَحْرُومُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5299,
      "ayahNumberInSurah": 28,
      "text": "قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5300,
      "ayahNumberInSurah": 29,
      "text": "قَالُوا۟ سُبْحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5301,
      "ayahNumberInSurah": 30,
      "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَلَٰوَمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5302,
      "ayahNumberInSurah": 31,
      "text": "قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا طَٰغِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5303,
      "ayahNumberInSurah": 32,
      "text": "عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًۭا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5304,
      "ayahNumberInSurah": 33,
      "text": "كَذَٰلِكَ ٱلْعَذَابُ ۖ وَلَعَذَابُ ٱلْءَاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 498,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5305,
      "ayahNumberInSurah": 34,
      "text": "إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّٰتِ ٱلنَّعِيمِ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5306,
      "ayahNumberInSurah": 35,
      "text": "أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5307,
      "ayahNumberInSurah": 36,
      "text": "مَا لَكُمْ كَيْفَ تَحْكُمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5308,
      "ayahNumberInSurah": 37,
      "text": "أَمْ لَكُمْ كِتَٰبٌۭ فِيهِ تَدْرُسُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5309,
      "ayahNumberInSurah": 38,
      "text": "إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5310,
      "ayahNumberInSurah": 39,
      "text": "أَمْ لَكُمْ أَيْمَٰنٌ عَلَيْنَا بَٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ ۙ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5311,
      "ayahNumberInSurah": 40,
      "text": "سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5312,
      "ayahNumberInSurah": 41,
      "text": "أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَٰدِقِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5313,
      "ayahNumberInSurah": 42,
      "text": "يَوْمَ يُكْشَفُ عَن سَاقٍۢ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 565,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5314,
      "ayahNumberInSurah": 43,
      "text": "خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌۭ ۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَٰلِمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5315,
      "ayahNumberInSurah": 44,
      "text": "فَذَرْنِى وَمَن يُكَذِّبُ بِهَٰذَا ٱلْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5316,
      "ayahNumberInSurah": 45,
      "text": "وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5317,
      "ayahNumberInSurah": 46,
      "text": "أَمْ تَسْـَٔلُهُمْ أَجْرًۭا فَهُم مِّن مَّغْرَمٍۢ مُّثْقَلُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5318,
      "ayahNumberInSurah": 47,
      "text": "أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5319,
      "ayahNumberInSurah": 48,
      "text": "فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5320,
      "ayahNumberInSurah": 49,
      "text": "لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٌۭ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
      "ayahNumber": 5321,
      "ayahNumberInSurah": 50,
      "text": "فَٱجْتَبَٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّٰلِحِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 566,
      "ruku": 499,
      "hizbQuarter": 226,
      "sajda": false
    },
    {
