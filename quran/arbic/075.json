{
  "metadata": {
    "surahNumber": 75,
    "surahNameArabic": "سُورَةُ القِيَامَةِ",
    "surahNameEnglish": "Al-Qiyaama",
    "surahNameTranslation": "The Resurrection",
    "revelationType": "Meccan",
    "numberOfAyahs": 40
  },
  "ayahs": [
    {
      "ayahNumber": 5552,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5553,
      "ayahNumberInSurah": 2,
      "text": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5554,
      "ayahNumberInSurah": 3,
      "text": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5555,
      "ayahNumberInSurah": 4,
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5556,
      "ayahNumberInSurah": 5,
      "text": "بَلْ يُرِيدُ ٱلْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5557,
      "ayahNumberInSurah": 6,
      "text": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَٰمَةِ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5558,
      "ayahNumberInSurah": 7,
      "text": "فَإِذَا بَرِقَ ٱلْبَصَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5559,
      "ayahNumberInSurah": 8,
      "text": "وَخَسَفَ ٱلْقَمَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5560,
      "ayahNumberInSurah": 9,
      "text": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5561,
      "ayahNumberInSurah": 10,
      "text": "يَقُولُ ٱلْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5562,
      "ayahNumberInSurah": 11,
      "text": "كَلَّا لَا وَزَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5563,
      "ayahNumberInSurah": 12,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5564,
      "ayahNumberInSurah": 13,
      "text": "يُنَبَّؤُا۟ ٱلْإِنسَٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5565,
      "ayahNumberInSurah": 14,
      "text": "بَلِ ٱلْإِنسَٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5566,
      "ayahNumberInSurah": 15,
      "text": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5567,
      "ayahNumberInSurah": 16,
      "text": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5568,
      "ayahNumberInSurah": 17,
      "text": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5569,
      "ayahNumberInSurah": 18,
      "text": "فَإِذَا قَرَأْنَٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5570,
      "ayahNumberInSurah": 19,
      "text": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5571,
      "ayahNumberInSurah": 20,
      "text": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5572,
      "ayahNumberInSurah": 21,
      "text": "وَتَذَرُونَ ٱلْءَاخِرَةَ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5573,
      "ayahNumberInSurah": 22,
      "text": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاضِرَةٌ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5574,
      "ayahNumberInSurah": 23,
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5575,
      "ayahNumberInSurah": 24,
      "text": "وَوُجُوهٌۭ يَوْمَئِذٍۭ بَاسِرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5576,
      "ayahNumberInSurah": 25,
      "text": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5577,
      "ayahNumberInSurah": 26,
      "text": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5578,
      "ayahNumberInSurah": 27,
      "text": "وَقِيلَ مَنْ ۜ رَاقٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5579,
      "ayahNumberInSurah": 28,
      "text": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5580,
      "ayahNumberInSurah": 29,
      "text": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5581,
      "ayahNumberInSurah": 30,
      "text": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 512,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5582,
      "ayahNumberInSurah": 31,
      "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5583,
      "ayahNumberInSurah": 32,
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5584,
      "ayahNumberInSurah": 33,
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5585,
      "ayahNumberInSurah": 34,
      "text": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5586,
      "ayahNumberInSurah": 35,
      "text": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5587,
      "ayahNumberInSurah": 36,
      "text": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَن يُتْرَكَ سُدًى",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5588,
      "ayahNumberInSurah": 37,
      "text": "أَلَمْ يَكُ نُطْفَةًۭ مِّن مَّنِىٍّۢ يُمْنَىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5589,
      "ayahNumberInSurah": 38,
      "text": "ثُمَّ كَانَ عَلَقَةًۭ فَخَلَقَ فَسَوَّىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5590,
      "ayahNumberInSurah": 39,
      "text": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
      "ruku": 513,
      "hizbQuarter": 231,
      "sajda": false
    },
    {
      "ayahNumber": 5591,
      "ayahNumberInSurah": 40,
      "text": "أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحْۦِىَ ٱلْمَوْتَىٰ",
      "juz": 29,
      "manzil": 7,
      "page": 578,
