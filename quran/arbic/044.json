  },
  "ayahs": [
    {
      "ayahNumber": 4415,
      "ayahNumberInSurah": 1,
      "text": " حمٓ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4416,
      "ayahNumberInSurah": 2,
      "text": "وَٱلْكِتَٰبِ ٱلْمُبِينِ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4417,
      "ayahNumberInSurah": 3,
      "text": "إِنَّآ أَنزَلْنَٰهُ فِى لَيْلَةٍۢ مُّبَٰرَكَةٍ ۚ إِنَّا كُنَّا مُنذِرِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4418,
      "ayahNumberInSurah": 4,
      "text": "فِيهَا يُفْرَقُ كُلُّ أَمْرٍ حَكِيمٍ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4419,
      "ayahNumberInSurah": 5,
      "text": "أَمْرًۭا مِّنْ عِندِنَآ ۚ إِنَّا كُنَّا مُرْسِلِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4420,
      "ayahNumberInSurah": 6,
      "text": "رَحْمَةًۭ مِّن رَّبِّكَ ۚ إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4421,
      "ayahNumberInSurah": 7,
      "text": "رَبِّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَآ ۖ إِن كُنتُم مُّوقِنِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4422,
      "ayahNumberInSurah": 8,
      "text": "لَآ إِلَٰهَ إِلَّا هُوَ يُحْىِۦ وَيُمِيتُ ۖ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4423,
      "ayahNumberInSurah": 9,
      "text": "بَلْ هُمْ فِى شَكٍّۢ يَلْعَبُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4424,
      "ayahNumberInSurah": 10,
      "text": "فَٱرْتَقِبْ يَوْمَ تَأْتِى ٱلسَّمَآءُ بِدُخَانٍۢ مُّبِينٍۢ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4425,
      "ayahNumberInSurah": 11,
      "text": "يَغْشَى ٱلنَّاسَ ۖ هَٰذَا عَذَابٌ أَلِيمٌۭ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4426,
      "ayahNumberInSurah": 12,
      "text": "رَّبَّنَا ٱكْشِفْ عَنَّا ٱلْعَذَابَ إِنَّا مُؤْمِنُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4427,
      "ayahNumberInSurah": 13,
      "text": "أَنَّىٰ لَهُمُ ٱلذِّكْرَىٰ وَقَدْ جَآءَهُمْ رَسُولٌۭ مُّبِينٌۭ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4428,
      "ayahNumberInSurah": 14,
      "text": "ثُمَّ تَوَلَّوْا۟ عَنْهُ وَقَالُوا۟ مُعَلَّمٌۭ مَّجْنُونٌ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4429,
      "ayahNumberInSurah": 15,
      "text": "إِنَّا كَاشِفُوا۟ ٱلْعَذَابِ قَلِيلًا ۚ إِنَّكُمْ عَآئِدُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4430,
      "ayahNumberInSurah": 16,
      "text": "يَوْمَ نَبْطِشُ ٱلْبَطْشَةَ ٱلْكُبْرَىٰٓ إِنَّا مُنتَقِمُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 198,
      "sajda": false
    },
    {
      "ayahNumber": 4431,
      "ayahNumberInSurah": 17,
      "text": "۞ وَلَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَجَآءَهُمْ رَسُولٌۭ كَرِيمٌ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4432,
      "ayahNumberInSurah": 18,
      "text": "أَنْ أَدُّوٓا۟ إِلَىَّ عِبَادَ ٱللَّهِ ۖ إِنِّى لَكُمْ رَسُولٌ أَمِينٌۭ",
      "juz": 25,
      "manzil": 6,
      "page": 496,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4433,
      "ayahNumberInSurah": 19,
      "text": "وَأَن لَّا تَعْلُوا۟ عَلَى ٱللَّهِ ۖ إِنِّىٓ ءَاتِيكُم بِسُلْطَٰنٍۢ مُّبِينٍۢ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4434,
      "ayahNumberInSurah": 20,
      "text": "وَإِنِّى عُذْتُ بِرَبِّى وَرَبِّكُمْ أَن تَرْجُمُونِ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4435,
      "ayahNumberInSurah": 21,
      "text": "وَإِن لَّمْ تُؤْمِنُوا۟ لِى فَٱعْتَزِلُونِ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4436,
      "ayahNumberInSurah": 22,
      "text": "فَدَعَا رَبَّهُۥٓ أَنَّ هَٰٓؤُلَآءِ قَوْمٌۭ مُّجْرِمُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4437,
      "ayahNumberInSurah": 23,
      "text": "فَأَسْرِ بِعِبَادِى لَيْلًا إِنَّكُم مُّتَّبَعُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4438,
      "ayahNumberInSurah": 24,
      "text": "وَٱتْرُكِ ٱلْبَحْرَ رَهْوًا ۖ إِنَّهُمْ جُندٌۭ مُّغْرَقُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4439,
      "ayahNumberInSurah": 25,
      "text": "كَمْ تَرَكُوا۟ مِن جَنَّٰتٍۢ وَعُيُونٍۢ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4440,
      "ayahNumberInSurah": 26,
      "text": "وَزُرُوعٍۢ وَمَقَامٍۢ كَرِيمٍۢ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4441,
      "ayahNumberInSurah": 27,
      "text": "وَنَعْمَةٍۢ كَانُوا۟ فِيهَا فَٰكِهِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4442,
      "ayahNumberInSurah": 28,
      "text": "كَذَٰلِكَ ۖ وَأَوْرَثْنَٰهَا قَوْمًا ءَاخَرِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4443,
      "ayahNumberInSurah": 29,
      "text": "فَمَا بَكَتْ عَلَيْهِمُ ٱلسَّمَآءُ وَٱلْأَرْضُ وَمَا كَانُوا۟ مُنظَرِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 431,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4444,
      "ayahNumberInSurah": 30,
      "text": "وَلَقَدْ نَجَّيْنَا بَنِىٓ إِسْرَٰٓءِيلَ مِنَ ٱلْعَذَابِ ٱلْمُهِينِ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4445,
      "ayahNumberInSurah": 31,
      "text": "مِن فِرْعَوْنَ ۚ إِنَّهُۥ كَانَ عَالِيًۭا مِّنَ ٱلْمُسْرِفِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4446,
      "ayahNumberInSurah": 32,
      "text": "وَلَقَدِ ٱخْتَرْنَٰهُمْ عَلَىٰ عِلْمٍ عَلَى ٱلْعَٰلَمِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4447,
      "ayahNumberInSurah": 33,
      "text": "وَءَاتَيْنَٰهُم مِّنَ ٱلْءَايَٰتِ مَا فِيهِ بَلَٰٓؤٌۭا۟ مُّبِينٌ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4448,
      "ayahNumberInSurah": 34,
      "text": "إِنَّ هَٰٓؤُلَآءِ لَيَقُولُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4449,
      "ayahNumberInSurah": 35,
      "text": "إِنْ هِىَ إِلَّا مَوْتَتُنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُنشَرِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4450,
      "ayahNumberInSurah": 36,
      "text": "فَأْتُوا۟ بِـَٔابَآئِنَآ إِن كُنتُمْ صَٰدِقِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4451,
      "ayahNumberInSurah": 37,
      "text": "أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّعٍۢ وَٱلَّذِينَ مِن قَبْلِهِمْ ۚ أَهْلَكْنَٰهُمْ ۖ إِنَّهُمْ كَانُوا۟ مُجْرِمِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4452,
      "ayahNumberInSurah": 38,
      "text": "وَمَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَا لَٰعِبِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4453,
      "ayahNumberInSurah": 39,
      "text": "مَا خَلَقْنَٰهُمَآ إِلَّا بِٱلْحَقِّ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 497,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4454,
      "ayahNumberInSurah": 40,
      "text": "إِنَّ يَوْمَ ٱلْفَصْلِ مِيقَٰتُهُمْ أَجْمَعِينَ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4455,
      "ayahNumberInSurah": 41,
      "text": "يَوْمَ لَا يُغْنِى مَوْلًى عَن مَّوْلًۭى شَيْـًۭٔا وَلَا هُمْ يُنصَرُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4456,
      "ayahNumberInSurah": 42,
      "text": "إِلَّا مَن رَّحِمَ ٱللَّهُ ۚ إِنَّهُۥ هُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 432,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4457,
      "ayahNumberInSurah": 43,
      "text": "إِنَّ شَجَرَتَ ٱلزَّقُّومِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4458,
      "ayahNumberInSurah": 44,
      "text": "طَعَامُ ٱلْأَثِيمِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4459,
      "ayahNumberInSurah": 45,
      "text": "كَٱلْمُهْلِ يَغْلِى فِى ٱلْبُطُونِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4460,
      "ayahNumberInSurah": 46,
      "text": "كَغَلْىِ ٱلْحَمِيمِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4461,
      "ayahNumberInSurah": 47,
      "text": "خُذُوهُ فَٱعْتِلُوهُ إِلَىٰ سَوَآءِ ٱلْجَحِيمِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4462,
      "ayahNumberInSurah": 48,
      "text": "ثُمَّ صُبُّوا۟ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ ٱلْحَمِيمِ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4463,
      "ayahNumberInSurah": 49,
      "text": "ذُقْ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْكَرِيمُ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4464,
      "ayahNumberInSurah": 50,
      "text": "إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَ",
      "juz": 25,
      "manzil": 6,
      "page": 498,
      "ruku": 433,
      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4465,
      "ayahNumberInSurah": 51,
      "text": "إِنَّ ٱلْمُتَّقِينَ فِى مَقَامٍ أَمِينٍۢ",
