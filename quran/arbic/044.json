      "hizbQuarter": 199,
      "sajda": false
    },
    {
      "ayahNumber": 4469,
      "ayahNumberInSurah": 55,
      "text": "يَدْعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَ",
