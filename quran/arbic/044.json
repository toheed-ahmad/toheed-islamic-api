      "sajda": false
    },
    {
      "ayahNumber": 4468,
      "ayahNumberInSurah": 54,
      "text": "كَذَٰلِكَ وَزَوَّجْنَٰهُم بِحُورٍ عِينٍۢ",
      "juz": 25,
      "manzil": 6,
