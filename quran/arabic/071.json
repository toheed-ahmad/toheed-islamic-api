  "ayahs": [
    {
      "ayahNumber": 5420,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ أَنْ أَنذِرْ قَوْمَكَ مِن قَبْلِ أَن يَأْتِيَهُمْ عَذَابٌ أَلِيمٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5421,
      "ayahNumberInSurah": 2,
      "text": "قَالَ يَٰقَوْمِ إِنِّى لَكُمْ نَذِيرٌۭ مُّبِينٌ",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5422,
      "ayahNumberInSurah": 3,
      "text": "أَنِ ٱعْبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِيعُونِ",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5423,
      "ayahNumberInSurah": 4,
      "text": "يَغْفِرْ لَكُم مِّن ذُنُوبِكُمْ وَيُؤَخِّرْكُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّى ۚ إِنَّ أَجَلَ ٱللَّهِ إِذَا جَآءَ لَا يُؤَخَّرُ ۖ لَوْ كُنتُمْ تَعْلَمُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5424,
      "ayahNumberInSurah": 5,
      "text": "قَالَ رَبِّ إِنِّى دَعَوْتُ قَوْمِى لَيْلًۭا وَنَهَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5425,
      "ayahNumberInSurah": 6,
      "text": "فَلَمْ يَزِدْهُمْ دُعَآءِىٓ إِلَّا فِرَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5426,
      "ayahNumberInSurah": 7,
      "text": "وَإِنِّى كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ جَعَلُوٓا۟ أَصَٰبِعَهُمْ فِىٓ ءَاذَانِهِمْ وَٱسْتَغْشَوْا۟ ثِيَابَهُمْ وَأَصَرُّوا۟ وَٱسْتَكْبَرُوا۟ ٱسْتِكْبَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5427,
      "ayahNumberInSurah": 8,
      "text": "ثُمَّ إِنِّى دَعَوْتُهُمْ جِهَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5428,
      "ayahNumberInSurah": 9,
      "text": "ثُمَّ إِنِّىٓ أَعْلَنتُ لَهُمْ وَأَسْرَرْتُ لَهُمْ إِسْرَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5429,
      "ayahNumberInSurah": 10,
      "text": "فَقُلْتُ ٱسْتَغْفِرُوا۟ رَبَّكُمْ إِنَّهُۥ كَانَ غَفَّارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 570,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5430,
      "ayahNumberInSurah": 11,
      "text": "يُرْسِلِ ٱلسَّمَآءَ عَلَيْكُم مِّدْرَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5431,
      "ayahNumberInSurah": 12,
      "text": "وَيُمْدِدْكُم بِأَمْوَٰلٍۢ وَبَنِينَ وَيَجْعَل لَّكُمْ جَنَّٰتٍۢ وَيَجْعَل لَّكُمْ أَنْهَٰرًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5432,
      "ayahNumberInSurah": 13,
      "text": "مَّا لَكُمْ لَا تَرْجُونَ لِلَّهِ وَقَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5433,
      "ayahNumberInSurah": 14,
      "text": "وَقَدْ خَلَقَكُمْ أَطْوَارًا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5434,
      "ayahNumberInSurah": 15,
      "text": "أَلَمْ تَرَوْا۟ كَيْفَ خَلَقَ ٱللَّهُ سَبْعَ سَمَٰوَٰتٍۢ طِبَاقًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5435,
      "ayahNumberInSurah": 16,
      "text": "وَجَعَلَ ٱلْقَمَرَ فِيهِنَّ نُورًۭا وَجَعَلَ ٱلشَّمْسَ سِرَاجًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5436,
      "ayahNumberInSurah": 17,
      "text": "وَٱللَّهُ أَنۢبَتَكُم مِّنَ ٱلْأَرْضِ نَبَاتًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5437,
      "ayahNumberInSurah": 18,
      "text": "ثُمَّ يُعِيدُكُمْ فِيهَا وَيُخْرِجُكُمْ إِخْرَاجًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5438,
      "ayahNumberInSurah": 19,
      "text": "وَٱللَّهُ جَعَلَ لَكُمُ ٱلْأَرْضَ بِسَاطًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5439,
      "ayahNumberInSurah": 20,
      "text": "لِّتَسْلُكُوا۟ مِنْهَا سُبُلًۭا فِجَاجًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 504,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5440,
      "ayahNumberInSurah": 21,
      "text": "قَالَ نُوحٌۭ رَّبِّ إِنَّهُمْ عَصَوْنِى وَٱتَّبَعُوا۟ مَن لَّمْ يَزِدْهُ مَالُهُۥ وَوَلَدُهُۥٓ إِلَّا خَسَارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 505,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5441,
      "ayahNumberInSurah": 22,
      "text": "وَمَكَرُوا۟ مَكْرًۭا كُبَّارًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 505,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5442,
      "ayahNumberInSurah": 23,
      "text": "وَقَالُوا۟ لَا تَذَرُنَّ ءَالِهَتَكُمْ وَلَا تَذَرُنَّ وَدًّۭا وَلَا سُوَاعًۭا وَلَا يَغُوثَ وَيَعُوقَ وَنَسْرًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 505,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5443,
      "ayahNumberInSurah": 24,
      "text": "وَقَدْ أَضَلُّوا۟ كَثِيرًۭا ۖ وَلَا تَزِدِ ٱلظَّٰلِمِينَ إِلَّا ضَلَٰلًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 571,
      "ruku": 505,
      "hizbQuarter": 228,
      "sajda": false
    },
    {
      "ayahNumber": 5444,
      "ayahNumberInSurah": 25,
      "text": "مِّمَّا خَطِيٓـَٰٔتِهِمْ أُغْرِقُوا۟ فَأُدْخِلُوا۟ نَارًۭا فَلَمْ يَجِدُوا۟ لَهُم مِّن دُونِ ٱللَّهِ أَنصَارًۭا",
      "juz": 29,
