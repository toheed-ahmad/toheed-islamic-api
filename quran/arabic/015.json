{
  "metadata": {
    "surahNumber": 15,
    "surahNameArabic": "سُورَةُ الحِجۡرِ",
    "surahNameEnglish": "Al-Hijr",
    "surahNameTranslation": "The Rock",
    "revelationType": "Meccan",
    "numberOfAyahs": 99
  },
  "ayahs": [
    {
      "ayahNumber": 1803,
      "ayahNumberInSurah": 1,
      "text": "الٓر ۚ تِلْكَ ءَايَٰتُ ٱلْكِتَٰبِ وَقُرْءَانٍۢ مُّبِينٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1804,
      "ayahNumberInSurah": 2,
      "text": "رُّبَمَا يَوَدُّ ٱلَّذِينَ كَفَرُوا۟ لَوْ كَانُوا۟ مُسْلِمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1805,
      "ayahNumberInSurah": 3,
      "text": "ذَرْهُمْ يَأْكُلُوا۟ وَيَتَمَتَّعُوا۟ وَيُلْهِهِمُ ٱلْأَمَلُ ۖ فَسَوْفَ يَعْلَمُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1806,
      "ayahNumberInSurah": 4,
      "text": "وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا وَلَهَا كِتَابٌۭ مَّعْلُومٌۭ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1807,
      "ayahNumberInSurah": 5,
      "text": "مَّا تَسْبِقُ مِنْ أُمَّةٍ أَجَلَهَا وَمَا يَسْتَـْٔخِرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1808,
      "ayahNumberInSurah": 6,
      "text": "وَقَالُوا۟ يَٰٓأَيُّهَا ٱلَّذِى نُزِّلَ عَلَيْهِ ٱلذِّكْرُ إِنَّكَ لَمَجْنُونٌۭ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1809,
      "ayahNumberInSurah": 7,
      "text": "لَّوْ مَا تَأْتِينَا بِٱلْمَلَٰٓئِكَةِ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1810,
      "ayahNumberInSurah": 8,
      "text": "مَا نُنَزِّلُ ٱلْمَلَٰٓئِكَةَ إِلَّا بِٱلْحَقِّ وَمَا كَانُوٓا۟ إِذًۭا مُّنظَرِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1811,
      "ayahNumberInSurah": 9,
      "text": "إِنَّا نَحْنُ نَزَّلْنَا ٱلذِّكْرَ وَإِنَّا لَهُۥ لَحَٰفِظُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1812,
      "ayahNumberInSurah": 10,
      "text": "وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ فِى شِيَعِ ٱلْأَوَّلِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1813,
      "ayahNumberInSurah": 11,
      "text": "وَمَا يَأْتِيهِم مِّن رَّسُولٍ إِلَّا كَانُوا۟ بِهِۦ يَسْتَهْزِءُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1814,
      "ayahNumberInSurah": 12,
      "text": "كَذَٰلِكَ نَسْلُكُهُۥ فِى قُلُوبِ ٱلْمُجْرِمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1815,
      "ayahNumberInSurah": 13,
      "text": "لَا يُؤْمِنُونَ بِهِۦ ۖ وَقَدْ خَلَتْ سُنَّةُ ٱلْأَوَّلِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1816,
      "ayahNumberInSurah": 14,
      "text": "وَلَوْ فَتَحْنَا عَلَيْهِم بَابًۭا مِّنَ ٱلسَّمَآءِ فَظَلُّوا۟ فِيهِ يَعْرُجُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1817,
      "ayahNumberInSurah": 15,
      "text": "لَقَالُوٓا۟ إِنَّمَا سُكِّرَتْ أَبْصَٰرُنَا بَلْ نَحْنُ قَوْمٌۭ مَّسْحُورُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 262,
      "ruku": 218,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1818,
      "ayahNumberInSurah": 16,
      "text": "وَلَقَدْ جَعَلْنَا فِى ٱلسَّمَآءِ بُرُوجًۭا وَزَيَّنَّٰهَا لِلنَّٰظِرِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1819,
      "ayahNumberInSurah": 17,
      "text": "وَحَفِظْنَٰهَا مِن كُلِّ شَيْطَٰنٍۢ رَّجِيمٍ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1820,
      "ayahNumberInSurah": 18,
      "text": "إِلَّا مَنِ ٱسْتَرَقَ ٱلسَّمْعَ فَأَتْبَعَهُۥ شِهَابٌۭ مُّبِينٌۭ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1821,
      "ayahNumberInSurah": 19,
      "text": "وَٱلْأَرْضَ مَدَدْنَٰهَا وَأَلْقَيْنَا فِيهَا رَوَٰسِىَ وَأَنۢبَتْنَا فِيهَا مِن كُلِّ شَىْءٍۢ مَّوْزُونٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1822,
      "ayahNumberInSurah": 20,
      "text": "وَجَعَلْنَا لَكُمْ فِيهَا مَعَٰيِشَ وَمَن لَّسْتُمْ لَهُۥ بِرَٰزِقِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1823,
      "ayahNumberInSurah": 21,
      "text": "وَإِن مِّن شَىْءٍ إِلَّا عِندَنَا خَزَآئِنُهُۥ وَمَا نُنَزِّلُهُۥٓ إِلَّا بِقَدَرٍۢ مَّعْلُومٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1824,
      "ayahNumberInSurah": 22,
      "text": "وَأَرْسَلْنَا ٱلرِّيَٰحَ لَوَٰقِحَ فَأَنزَلْنَا مِنَ ٱلسَّمَآءِ مَآءًۭ فَأَسْقَيْنَٰكُمُوهُ وَمَآ أَنتُمْ لَهُۥ بِخَٰزِنِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1825,
      "ayahNumberInSurah": 23,
      "text": "وَإِنَّا لَنَحْنُ نُحْىِۦ وَنُمِيتُ وَنَحْنُ ٱلْوَٰرِثُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1826,
      "ayahNumberInSurah": 24,
      "text": "وَلَقَدْ عَلِمْنَا ٱلْمُسْتَقْدِمِينَ مِنكُمْ وَلَقَدْ عَلِمْنَا ٱلْمُسْتَـْٔخِرِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1827,
      "ayahNumberInSurah": 25,
      "text": "وَإِنَّ رَبَّكَ هُوَ يَحْشُرُهُمْ ۚ إِنَّهُۥ حَكِيمٌ عَلِيمٌۭ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 219,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1828,
      "ayahNumberInSurah": 26,
      "text": "وَلَقَدْ خَلَقْنَا ٱلْإِنسَٰنَ مِن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1829,
      "ayahNumberInSurah": 27,
      "text": "وَٱلْجَآنَّ خَلَقْنَٰهُ مِن قَبْلُ مِن نَّارِ ٱلسَّمُومِ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1830,
      "ayahNumberInSurah": 28,
      "text": "وَإِذْ قَالَ رَبُّكَ لِلْمَلَٰٓئِكَةِ إِنِّى خَٰلِقٌۢ بَشَرًۭا مِّن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1831,
      "ayahNumberInSurah": 29,
      "text": "فَإِذَا سَوَّيْتُهُۥ وَنَفَخْتُ فِيهِ مِن رُّوحِى فَقَعُوا۟ لَهُۥ سَٰجِدِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1832,
      "ayahNumberInSurah": 30,
      "text": "فَسَجَدَ ٱلْمَلَٰٓئِكَةُ كُلُّهُمْ أَجْمَعُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1833,
      "ayahNumberInSurah": 31,
      "text": "إِلَّآ إِبْلِيسَ أَبَىٰٓ أَن يَكُونَ مَعَ ٱلسَّٰجِدِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 263,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1834,
      "ayahNumberInSurah": 32,
      "text": "قَالَ يَٰٓإِبْلِيسُ مَا لَكَ أَلَّا تَكُونَ مَعَ ٱلسَّٰجِدِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1835,
      "ayahNumberInSurah": 33,
      "text": "قَالَ لَمْ أَكُن لِّأَسْجُدَ لِبَشَرٍ خَلَقْتَهُۥ مِن صَلْصَٰلٍۢ مِّنْ حَمَإٍۢ مَّسْنُونٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1836,
      "ayahNumberInSurah": 34,
      "text": "قَالَ فَٱخْرُجْ مِنْهَا فَإِنَّكَ رَجِيمٌۭ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1837,
      "ayahNumberInSurah": 35,
      "text": "وَإِنَّ عَلَيْكَ ٱللَّعْنَةَ إِلَىٰ يَوْمِ ٱلدِّينِ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1838,
      "ayahNumberInSurah": 36,
      "text": "قَالَ رَبِّ فَأَنظِرْنِىٓ إِلَىٰ يَوْمِ يُبْعَثُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1839,
      "ayahNumberInSurah": 37,
      "text": "قَالَ فَإِنَّكَ مِنَ ٱلْمُنظَرِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1840,
      "ayahNumberInSurah": 38,
      "text": "إِلَىٰ يَوْمِ ٱلْوَقْتِ ٱلْمَعْلُومِ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1841,
      "ayahNumberInSurah": 39,
      "text": "قَالَ رَبِّ بِمَآ أَغْوَيْتَنِى لَأُزَيِّنَنَّ لَهُمْ فِى ٱلْأَرْضِ وَلَأُغْوِيَنَّهُمْ أَجْمَعِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1842,
      "ayahNumberInSurah": 40,
      "text": "إِلَّا عِبَادَكَ مِنْهُمُ ٱلْمُخْلَصِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1843,
      "ayahNumberInSurah": 41,
      "text": "قَالَ هَٰذَا صِرَٰطٌ عَلَىَّ مُسْتَقِيمٌ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1844,
      "ayahNumberInSurah": 42,
      "text": "إِنَّ عِبَادِى لَيْسَ لَكَ عَلَيْهِمْ سُلْطَٰنٌ إِلَّا مَنِ ٱتَّبَعَكَ مِنَ ٱلْغَاوِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1845,
      "ayahNumberInSurah": 43,
      "text": "وَإِنَّ جَهَنَّمَ لَمَوْعِدُهُمْ أَجْمَعِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1846,
      "ayahNumberInSurah": 44,
      "text": "لَهَا سَبْعَةُ أَبْوَٰبٍۢ لِّكُلِّ بَابٍۢ مِّنْهُمْ جُزْءٌۭ مَّقْسُومٌ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 220,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1847,
      "ayahNumberInSurah": 45,
      "text": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّٰتٍۢ وَعُيُونٍ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1848,
      "ayahNumberInSurah": 46,
      "text": "ٱدْخُلُوهَا بِسَلَٰمٍ ءَامِنِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1849,
      "ayahNumberInSurah": 47,
      "text": "وَنَزَعْنَا مَا فِى صُدُورِهِم مِّنْ غِلٍّ إِخْوَٰنًا عَلَىٰ سُرُرٍۢ مُّتَقَٰبِلِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1850,
      "ayahNumberInSurah": 48,
      "text": "لَا يَمَسُّهُمْ فِيهَا نَصَبٌۭ وَمَا هُم مِّنْهَا بِمُخْرَجِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1851,
      "ayahNumberInSurah": 49,
      "text": "۞ نَبِّئْ عِبَادِىٓ أَنِّىٓ أَنَا ٱلْغَفُورُ ٱلرَّحِيمُ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 105,
      "sajda": false
    },
    {
      "ayahNumber": 1852,
      "ayahNumberInSurah": 50,
      "text": "وَأَنَّ عَذَابِى هُوَ ٱلْعَذَابُ ٱلْأَلِيمُ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1853,
      "ayahNumberInSurah": 51,
      "text": "وَنَبِّئْهُمْ عَن ضَيْفِ إِبْرَٰهِيمَ",
      "juz": 14,
      "manzil": 3,
      "page": 264,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1854,
      "ayahNumberInSurah": 52,
      "text": "إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَٰمًۭا قَالَ إِنَّا مِنكُمْ وَجِلُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1855,
      "ayahNumberInSurah": 53,
      "text": "قَالُوا۟ لَا تَوْجَلْ إِنَّا نُبَشِّرُكَ بِغُلَٰمٍ عَلِيمٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1856,
      "ayahNumberInSurah": 54,
      "text": "قَالَ أَبَشَّرْتُمُونِى عَلَىٰٓ أَن مَّسَّنِىَ ٱلْكِبَرُ فَبِمَ تُبَشِّرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1857,
      "ayahNumberInSurah": 55,
      "text": "قَالُوا۟ بَشَّرْنَٰكَ بِٱلْحَقِّ فَلَا تَكُن مِّنَ ٱلْقَٰنِطِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1858,
      "ayahNumberInSurah": 56,
      "text": "قَالَ وَمَن يَقْنَطُ مِن رَّحْمَةِ رَبِّهِۦٓ إِلَّا ٱلضَّآلُّونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1859,
      "ayahNumberInSurah": 57,
      "text": "قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1860,
      "ayahNumberInSurah": 58,
      "text": "قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍۢ مُّجْرِمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1861,
      "ayahNumberInSurah": 59,
      "text": "إِلَّآ ءَالَ لُوطٍ إِنَّا لَمُنَجُّوهُمْ أَجْمَعِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1862,
      "ayahNumberInSurah": 60,
      "text": "إِلَّا ٱمْرَأَتَهُۥ قَدَّرْنَآ ۙ إِنَّهَا لَمِنَ ٱلْغَٰبِرِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 221,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1863,
      "ayahNumberInSurah": 61,
      "text": "فَلَمَّا جَآءَ ءَالَ لُوطٍ ٱلْمُرْسَلُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1864,
      "ayahNumberInSurah": 62,
      "text": "قَالَ إِنَّكُمْ قَوْمٌۭ مُّنكَرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1865,
      "ayahNumberInSurah": 63,
      "text": "قَالُوا۟ بَلْ جِئْنَٰكَ بِمَا كَانُوا۟ فِيهِ يَمْتَرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1866,
      "ayahNumberInSurah": 64,
      "text": "وَأَتَيْنَٰكَ بِٱلْحَقِّ وَإِنَّا لَصَٰدِقُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1867,
      "ayahNumberInSurah": 65,
      "text": "فَأَسْرِ بِأَهْلِكَ بِقِطْعٍۢ مِّنَ ٱلَّيْلِ وَٱتَّبِعْ أَدْبَٰرَهُمْ وَلَا يَلْتَفِتْ مِنكُمْ أَحَدٌۭ وَٱمْضُوا۟ حَيْثُ تُؤْمَرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1868,
      "ayahNumberInSurah": 66,
      "text": "وَقَضَيْنَآ إِلَيْهِ ذَٰلِكَ ٱلْأَمْرَ أَنَّ دَابِرَ هَٰٓؤُلَآءِ مَقْطُوعٌۭ مُّصْبِحِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1869,
      "ayahNumberInSurah": 67,
      "text": "وَجَآءَ أَهْلُ ٱلْمَدِينَةِ يَسْتَبْشِرُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1870,
      "ayahNumberInSurah": 68,
      "text": "قَالَ إِنَّ هَٰٓؤُلَآءِ ضَيْفِى فَلَا تَفْضَحُونِ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1871,
      "ayahNumberInSurah": 69,
      "text": "وَٱتَّقُوا۟ ٱللَّهَ وَلَا تُخْزُونِ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1872,
      "ayahNumberInSurah": 70,
      "text": "قَالُوٓا۟ أَوَلَمْ نَنْهَكَ عَنِ ٱلْعَٰلَمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 265,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1873,
      "ayahNumberInSurah": 71,
      "text": "قَالَ هَٰٓؤُلَآءِ بَنَاتِىٓ إِن كُنتُمْ فَٰعِلِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1874,
      "ayahNumberInSurah": 72,
      "text": "لَعَمْرُكَ إِنَّهُمْ لَفِى سَكْرَتِهِمْ يَعْمَهُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1875,
      "ayahNumberInSurah": 73,
      "text": "فَأَخَذَتْهُمُ ٱلصَّيْحَةُ مُشْرِقِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1876,
      "ayahNumberInSurah": 74,
      "text": "فَجَعَلْنَا عَٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةًۭ مِّن سِجِّيلٍ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1877,
      "ayahNumberInSurah": 75,
      "text": "إِنَّ فِى ذَٰلِكَ لَءَايَٰتٍۢ لِّلْمُتَوَسِّمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1878,
      "ayahNumberInSurah": 76,
      "text": "وَإِنَّهَا لَبِسَبِيلٍۢ مُّقِيمٍ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1879,
      "ayahNumberInSurah": 77,
      "text": "إِنَّ فِى ذَٰلِكَ لَءَايَةًۭ لِّلْمُؤْمِنِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1880,
      "ayahNumberInSurah": 78,
      "text": "وَإِن كَانَ أَصْحَٰبُ ٱلْأَيْكَةِ لَظَٰلِمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1881,
      "ayahNumberInSurah": 79,
      "text": "فَٱنتَقَمْنَا مِنْهُمْ وَإِنَّهُمَا لَبِإِمَامٍۢ مُّبِينٍۢ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 222,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1882,
      "ayahNumberInSurah": 80,
      "text": "وَلَقَدْ كَذَّبَ أَصْحَٰبُ ٱلْحِجْرِ ٱلْمُرْسَلِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1883,
      "ayahNumberInSurah": 81,
      "text": "وَءَاتَيْنَٰهُمْ ءَايَٰتِنَا فَكَانُوا۟ عَنْهَا مُعْرِضِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1884,
      "ayahNumberInSurah": 82,
      "text": "وَكَانُوا۟ يَنْحِتُونَ مِنَ ٱلْجِبَالِ بُيُوتًا ءَامِنِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1885,
      "ayahNumberInSurah": 83,
      "text": "فَأَخَذَتْهُمُ ٱلصَّيْحَةُ مُصْبِحِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1886,
      "ayahNumberInSurah": 84,
      "text": "فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1887,
      "ayahNumberInSurah": 85,
      "text": "وَمَا خَلَقْنَا ٱلسَّمَٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ ۗ وَإِنَّ ٱلسَّاعَةَ لَءَاتِيَةٌۭ ۖ فَٱصْفَحِ ٱلصَّفْحَ ٱلْجَمِيلَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1888,
      "ayahNumberInSurah": 86,
      "text": "إِنَّ رَبَّكَ هُوَ ٱلْخَلَّٰقُ ٱلْعَلِيمُ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1889,
      "ayahNumberInSurah": 87,
      "text": "وَلَقَدْ ءَاتَيْنَٰكَ سَبْعًۭا مِّنَ ٱلْمَثَانِى وَٱلْقُرْءَانَ ٱلْعَظِيمَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1890,
      "ayahNumberInSurah": 88,
      "text": "لَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًۭا مِّنْهُمْ وَلَا تَحْزَنْ عَلَيْهِمْ وَٱخْفِضْ جَنَاحَكَ لِلْمُؤْمِنِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1891,
      "ayahNumberInSurah": 89,
      "text": "وَقُلْ إِنِّىٓ أَنَا ٱلنَّذِيرُ ٱلْمُبِينُ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1892,
      "ayahNumberInSurah": 90,
      "text": "كَمَآ أَنزَلْنَا عَلَى ٱلْمُقْتَسِمِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 266,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1893,
      "ayahNumberInSurah": 91,
      "text": "ٱلَّذِينَ جَعَلُوا۟ ٱلْقُرْءَانَ عِضِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 267,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1894,
      "ayahNumberInSurah": 92,
      "text": "فَوَرَبِّكَ لَنَسْـَٔلَنَّهُمْ أَجْمَعِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 267,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1895,
      "ayahNumberInSurah": 93,
      "text": "عَمَّا كَانُوا۟ يَعْمَلُونَ",
      "juz": 14,
      "manzil": 3,
      "page": 267,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1896,
      "ayahNumberInSurah": 94,
      "text": "فَٱصْدَعْ بِمَا تُؤْمَرُ وَأَعْرِضْ عَنِ ٱلْمُشْرِكِينَ",
      "juz": 14,
      "manzil": 3,
      "page": 267,
      "ruku": 223,
      "hizbQuarter": 106,
      "sajda": false
    },
    {
      "ayahNumber": 1897,
