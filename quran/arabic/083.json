{
  "metadata": {
    "surahNumber": 83,
    "surahNameArabic": "سُورَةُ المُطَفِّفِينَ",
    "surahNameEnglish": "Al-Mutaffifin",
    "surahNameTranslation": "Defrauding",
    "revelationType": "Meccan",
