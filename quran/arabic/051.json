      "hizbQuarter": 209,
      "sajda": false
    },
    {
      "ayahNumber": 4729,
      "ayahNumberInSurah": 54,
      "text": "فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍۢ",
      "juz": 27,
      "manzil": 7,
