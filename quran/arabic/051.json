      "hizbQuarter": 209,
      "sajda": false
    },
    {
      "ayahNumber": 4730,
      "ayahNumberInSurah": 55,
      "text": "وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ",
      "juz": 27,
