      "hizbQuarter": 209,
      "sajda": false
    },
    {
      "ayahNumber": 4728,
      "ayahNumberInSurah": 53,
      "text": "أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌۭ طَاغُونَ",
      "juz": 27,
      "manzil": 7,
