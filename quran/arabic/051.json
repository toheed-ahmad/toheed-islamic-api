      "hizbQuarter": 209,
      "sajda": false
    },
    {
      "ayahNumber": 4731,
      "ayahNumberInSurah": 56,
      "text": "وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ",
      "juz": 27,
      "manzil": 7,
      "page": 523,
      "ruku": 457,
      "hizbQuarter": 209,
      "sajda": false
    },
    {
      "ayahNumber": 4732,
      "ayahNumberInSurah": 57,
      "text": "مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍۢ وَمَآ أُرِيدُ أَن يُطْعِمُونِ",
