      "ayahNumberInSurah": 159,
      "text": "سُبْحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
