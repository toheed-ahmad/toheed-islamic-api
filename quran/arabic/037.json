{
  "metadata": {
    "surahNumber": 37,
    "surahNameArabic": "سُورَةُ الصَّافَّاتِ",
    "surahNameEnglish": "As-Saaffaat",
    "surahNameTranslation": "Those drawn up in Ranks",
    "revelationType": "Meccan",
    "numberOfAyahs": 182
  },
  "ayahs": [
    {
      "ayahNumber": 3789,
      "ayahNumberInSurah": 1,
      "text": "وَٱلصَّٰٓفَّٰتِ صَفًّۭا",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3790,
      "ayahNumberInSurah": 2,
      "text": "فَٱلزَّٰجِرَٰتِ زَجْرًۭا",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3791,
      "ayahNumberInSurah": 3,
      "text": "فَٱلتَّٰلِيَٰتِ ذِكْرًا",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3792,
      "ayahNumberInSurah": 4,
      "text": "إِنَّ إِلَٰهَكُمْ لَوَٰحِدٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3793,
      "ayahNumberInSurah": 5,
      "text": "رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا وَرَبُّ ٱلْمَشَٰرِقِ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3794,
      "ayahNumberInSurah": 6,
      "text": "إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنْيَا بِزِينَةٍ ٱلْكَوَاكِبِ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3795,
      "ayahNumberInSurah": 7,
      "text": "وَحِفْظًۭا مِّن كُلِّ شَيْطَٰنٍۢ مَّارِدٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3796,
      "ayahNumberInSurah": 8,
      "text": "لَّا يَسَّمَّعُونَ إِلَى ٱلْمَلَإِ ٱلْأَعْلَىٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3797,
      "ayahNumberInSurah": 9,
      "text": "دُحُورًۭا ۖ وَلَهُمْ عَذَابٌۭ وَاصِبٌ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3798,
      "ayahNumberInSurah": 10,
      "text": "إِلَّا مَنْ خَطِفَ ٱلْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٌۭ ثَاقِبٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3799,
      "ayahNumberInSurah": 11,
      "text": "فَٱسْتَفْتِهِمْ أَهُمْ أَشَدُّ خَلْقًا أَم مَّنْ خَلَقْنَآ ۚ إِنَّا خَلَقْنَٰهُم مِّن طِينٍۢ لَّازِبٍۭ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3800,
      "ayahNumberInSurah": 12,
      "text": "بَلْ عَجِبْتَ وَيَسْخَرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3801,
      "ayahNumberInSurah": 13,
      "text": "وَإِذَا ذُكِّرُوا۟ لَا يَذْكُرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3802,
      "ayahNumberInSurah": 14,
      "text": "وَإِذَا رَأَوْا۟ ءَايَةًۭ يَسْتَسْخِرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3803,
      "ayahNumberInSurah": 15,
      "text": "وَقَالُوٓا۟ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ مُّبِينٌ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3804,
      "ayahNumberInSurah": 16,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3805,
      "ayahNumberInSurah": 17,
      "text": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3806,
      "ayahNumberInSurah": 18,
      "text": "قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3807,
      "ayahNumberInSurah": 19,
      "text": "فَإِنَّمَا هِىَ زَجْرَةٌۭ وَٰحِدَةٌۭ فَإِذَا هُمْ يَنظُرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3808,
      "ayahNumberInSurah": 20,
      "text": "وَقَالُوا۟ يَٰوَيْلَنَا هَٰذَا يَوْمُ ٱلدِّينِ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3809,
      "ayahNumberInSurah": 21,
      "text": "هَٰذَا يَوْمُ ٱلْفَصْلِ ٱلَّذِى كُنتُم بِهِۦ تُكَذِّبُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 386,
      "hizbQuarter": 178,
      "sajda": false
    },
    {
      "ayahNumber": 3810,
      "ayahNumberInSurah": 22,
      "text": "۞ ٱحْشُرُوا۟ ٱلَّذِينَ ظَلَمُوا۟ وَأَزْوَٰجَهُمْ وَمَا كَانُوا۟ يَعْبُدُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3811,
      "ayahNumberInSurah": 23,
      "text": "مِن دُونِ ٱللَّهِ فَٱهْدُوهُمْ إِلَىٰ صِرَٰطِ ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3812,
      "ayahNumberInSurah": 24,
      "text": "وَقِفُوهُمْ ۖ إِنَّهُم مَّسْـُٔولُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 446,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3813,
      "ayahNumberInSurah": 25,
      "text": "مَا لَكُمْ لَا تَنَاصَرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3814,
      "ayahNumberInSurah": 26,
      "text": "بَلْ هُمُ ٱلْيَوْمَ مُسْتَسْلِمُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3815,
      "ayahNumberInSurah": 27,
      "text": "وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَسَآءَلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3816,
      "ayahNumberInSurah": 28,
      "text": "قَالُوٓا۟ إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ ٱلْيَمِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3817,
      "ayahNumberInSurah": 29,
      "text": "قَالُوا۟ بَل لَّمْ تَكُونُوا۟ مُؤْمِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3818,
      "ayahNumberInSurah": 30,
      "text": "وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَٰنٍۭ ۖ بَلْ كُنتُمْ قَوْمًۭا طَٰغِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3819,
      "ayahNumberInSurah": 31,
      "text": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ ۖ إِنَّا لَذَآئِقُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3820,
      "ayahNumberInSurah": 32,
      "text": "فَأَغْوَيْنَٰكُمْ إِنَّا كُنَّا غَٰوِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3821,
      "ayahNumberInSurah": 33,
      "text": "فَإِنَّهُمْ يَوْمَئِذٍۢ فِى ٱلْعَذَابِ مُشْتَرِكُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3822,
      "ayahNumberInSurah": 34,
      "text": "إِنَّا كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3823,
      "ayahNumberInSurah": 35,
      "text": "إِنَّهُمْ كَانُوٓا۟ إِذَا قِيلَ لَهُمْ لَآ إِلَٰهَ إِلَّا ٱللَّهُ يَسْتَكْبِرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3824,
      "ayahNumberInSurah": 36,
      "text": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓا۟ ءَالِهَتِنَا لِشَاعِرٍۢ مَّجْنُونٍۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3825,
      "ayahNumberInSurah": 37,
      "text": "بَلْ جَآءَ بِٱلْحَقِّ وَصَدَّقَ ٱلْمُرْسَلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3826,
      "ayahNumberInSurah": 38,
      "text": "إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3827,
      "ayahNumberInSurah": 39,
      "text": "وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3828,
      "ayahNumberInSurah": 40,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3829,
      "ayahNumberInSurah": 41,
      "text": "أُو۟لَٰٓئِكَ لَهُمْ رِزْقٌۭ مَّعْلُومٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3830,
      "ayahNumberInSurah": 42,
      "text": "فَوَٰكِهُ ۖ وَهُم مُّكْرَمُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3831,
      "ayahNumberInSurah": 43,
      "text": "فِى جَنَّٰتِ ٱلنَّعِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3832,
      "ayahNumberInSurah": 44,
      "text": "عَلَىٰ سُرُرٍۢ مُّتَقَٰبِلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3833,
      "ayahNumberInSurah": 45,
      "text": "يُطَافُ عَلَيْهِم بِكَأْسٍۢ مِّن مَّعِينٍۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3834,
      "ayahNumberInSurah": 46,
      "text": "بَيْضَآءَ لَذَّةٍۢ لِّلشَّٰرِبِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3835,
      "ayahNumberInSurah": 47,
      "text": "لَا فِيهَا غَوْلٌۭ وَلَا هُمْ عَنْهَا يُنزَفُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3836,
      "ayahNumberInSurah": 48,
      "text": "وَعِندَهُمْ قَٰصِرَٰتُ ٱلطَّرْفِ عِينٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3837,
      "ayahNumberInSurah": 49,
      "text": "كَأَنَّهُنَّ بَيْضٌۭ مَّكْنُونٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3838,
      "ayahNumberInSurah": 50,
      "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَسَآءَلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3839,
      "ayahNumberInSurah": 51,
      "text": "قَالَ قَآئِلٌۭ مِّنْهُمْ إِنِّى كَانَ لِى قَرِينٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 447,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3840,
      "ayahNumberInSurah": 52,
      "text": "يَقُولُ أَءِنَّكَ لَمِنَ ٱلْمُصَدِّقِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3841,
      "ayahNumberInSurah": 53,
      "text": "أَءِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَدِينُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3842,
      "ayahNumberInSurah": 54,
      "text": "قَالَ هَلْ أَنتُم مُّطَّلِعُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3843,
      "ayahNumberInSurah": 55,
      "text": "فَٱطَّلَعَ فَرَءَاهُ فِى سَوَآءِ ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3844,
      "ayahNumberInSurah": 56,
      "text": "قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرْدِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3845,
      "ayahNumberInSurah": 57,
      "text": "وَلَوْلَا نِعْمَةُ رَبِّى لَكُنتُ مِنَ ٱلْمُحْضَرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3846,
      "ayahNumberInSurah": 58,
      "text": "أَفَمَا نَحْنُ بِمَيِّتِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3847,
      "ayahNumberInSurah": 59,
      "text": "إِلَّا مَوْتَتَنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3848,
      "ayahNumberInSurah": 60,
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلْفَوْزُ ٱلْعَظِيمُ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3849,
      "ayahNumberInSurah": 61,
      "text": "لِمِثْلِ هَٰذَا فَلْيَعْمَلِ ٱلْعَٰمِلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3850,
      "ayahNumberInSurah": 62,
      "text": "أَذَٰلِكَ خَيْرٌۭ نُّزُلًا أَمْ شَجَرَةُ ٱلزَّقُّومِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3851,
      "ayahNumberInSurah": 63,
      "text": "إِنَّا جَعَلْنَٰهَا فِتْنَةًۭ لِّلظَّٰلِمِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3852,
      "ayahNumberInSurah": 64,
      "text": "إِنَّهَا شَجَرَةٌۭ تَخْرُجُ فِىٓ أَصْلِ ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3853,
      "ayahNumberInSurah": 65,
      "text": "طَلْعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَٰطِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3854,
      "ayahNumberInSurah": 66,
      "text": "فَإِنَّهُمْ لَءَاكِلُونَ مِنْهَا فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3855,
      "ayahNumberInSurah": 67,
      "text": "ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْبًۭا مِّنْ حَمِيمٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3856,
      "ayahNumberInSurah": 68,
      "text": "ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَى ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3857,
      "ayahNumberInSurah": 69,
      "text": "إِنَّهُمْ أَلْفَوْا۟ ءَابَآءَهُمْ ضَآلِّينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3858,
      "ayahNumberInSurah": 70,
      "text": "فَهُمْ عَلَىٰٓ ءَاثَٰرِهِمْ يُهْرَعُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3859,
      "ayahNumberInSurah": 71,
      "text": "وَلَقَدْ ضَلَّ قَبْلَهُمْ أَكْثَرُ ٱلْأَوَّلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3860,
      "ayahNumberInSurah": 72,
      "text": "وَلَقَدْ أَرْسَلْنَا فِيهِم مُّنذِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3861,
      "ayahNumberInSurah": 73,
      "text": "فَٱنظُرْ كَيْفَ كَانَ عَٰقِبَةُ ٱلْمُنذَرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3862,
      "ayahNumberInSurah": 74,
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 387,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3863,
      "ayahNumberInSurah": 75,
      "text": "وَلَقَدْ نَادَىٰنَا نُوحٌۭ فَلَنِعْمَ ٱلْمُجِيبُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3864,
      "ayahNumberInSurah": 76,
      "text": "وَنَجَّيْنَٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 448,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3865,
      "ayahNumberInSurah": 77,
      "text": "وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ ٱلْبَاقِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3866,
      "ayahNumberInSurah": 78,
      "text": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3867,
      "ayahNumberInSurah": 79,
      "text": "سَلَٰمٌ عَلَىٰ نُوحٍۢ فِى ٱلْعَٰلَمِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3868,
      "ayahNumberInSurah": 80,
      "text": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3869,
      "ayahNumberInSurah": 81,
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3870,
      "ayahNumberInSurah": 82,
      "text": "ثُمَّ أَغْرَقْنَا ٱلْءَاخَرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 179,
      "sajda": false
    },
    {
      "ayahNumber": 3871,
      "ayahNumberInSurah": 83,
      "text": "۞ وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3872,
      "ayahNumberInSurah": 84,
      "text": "إِذْ جَآءَ رَبَّهُۥ بِقَلْبٍۢ سَلِيمٍ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3873,
      "ayahNumberInSurah": 85,
      "text": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3874,
      "ayahNumberInSurah": 86,
      "text": "أَئِفْكًا ءَالِهَةًۭ دُونَ ٱللَّهِ تُرِيدُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3875,
      "ayahNumberInSurah": 87,
      "text": "فَمَا ظَنُّكُم بِرَبِّ ٱلْعَٰلَمِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3876,
      "ayahNumberInSurah": 88,
      "text": "فَنَظَرَ نَظْرَةًۭ فِى ٱلنُّجُومِ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3877,
      "ayahNumberInSurah": 89,
      "text": "فَقَالَ إِنِّى سَقِيمٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3878,
      "ayahNumberInSurah": 90,
      "text": "فَتَوَلَّوْا۟ عَنْهُ مُدْبِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3879,
      "ayahNumberInSurah": 91,
      "text": "فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3880,
      "ayahNumberInSurah": 92,
      "text": "مَا لَكُمْ لَا تَنطِقُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3881,
      "ayahNumberInSurah": 93,
      "text": "فَرَاغَ عَلَيْهِمْ ضَرْبًۢا بِٱلْيَمِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3882,
      "ayahNumberInSurah": 94,
      "text": "فَأَقْبَلُوٓا۟ إِلَيْهِ يَزِفُّونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3883,
      "ayahNumberInSurah": 95,
      "text": "قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3884,
      "ayahNumberInSurah": 96,
      "text": "وَٱللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3885,
      "ayahNumberInSurah": 97,
      "text": "قَالُوا۟ ٱبْنُوا۟ لَهُۥ بُنْيَٰنًۭا فَأَلْقُوهُ فِى ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3886,
      "ayahNumberInSurah": 98,
      "text": "فَأَرَادُوا۟ بِهِۦ كَيْدًۭا فَجَعَلْنَٰهُمُ ٱلْأَسْفَلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3887,
      "ayahNumberInSurah": 99,
      "text": "وَقَالَ إِنِّى ذَاهِبٌ إِلَىٰ رَبِّى سَيَهْدِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3888,
      "ayahNumberInSurah": 100,
      "text": "رَبِّ هَبْ لِى مِنَ ٱلصَّٰلِحِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3889,
      "ayahNumberInSurah": 101,
      "text": "فَبَشَّرْنَٰهُ بِغُلَٰمٍ حَلِيمٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3890,
      "ayahNumberInSurah": 102,
      "text": "فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعْىَ قَالَ يَٰبُنَىَّ إِنِّىٓ أَرَىٰ فِى ٱلْمَنَامِ أَنِّىٓ أَذْبَحُكَ فَٱنظُرْ مَاذَا تَرَىٰ ۚ قَالَ يَٰٓأَبَتِ ٱفْعَلْ مَا تُؤْمَرُ ۖ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّٰبِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 449,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3891,
      "ayahNumberInSurah": 103,
      "text": "فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3892,
      "ayahNumberInSurah": 104,
      "text": "وَنَٰدَيْنَٰهُ أَن يَٰٓإِبْرَٰهِيمُ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3893,
      "ayahNumberInSurah": 105,
      "text": "قَدْ صَدَّقْتَ ٱلرُّءْيَآ ۚ إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3894,
      "ayahNumberInSurah": 106,
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلْبَلَٰٓؤُا۟ ٱلْمُبِينُ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3895,
      "ayahNumberInSurah": 107,
      "text": "وَفَدَيْنَٰهُ بِذِبْحٍ عَظِيمٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3896,
      "ayahNumberInSurah": 108,
      "text": "وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3897,
      "ayahNumberInSurah": 109,
      "text": "سَلَٰمٌ عَلَىٰٓ إِبْرَٰهِيمَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3898,
      "ayahNumberInSurah": 110,
      "text": "كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3899,
      "ayahNumberInSurah": 111,
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3900,
      "ayahNumberInSurah": 112,
      "text": "وَبَشَّرْنَٰهُ بِإِسْحَٰقَ نَبِيًّۭا مِّنَ ٱلصَّٰلِحِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3901,
      "ayahNumberInSurah": 113,
      "text": "وَبَٰرَكْنَا عَلَيْهِ وَعَلَىٰٓ إِسْحَٰقَ ۚ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٌۭ وَظَالِمٌۭ لِّنَفْسِهِۦ مُبِينٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 388,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3902,
      "ayahNumberInSurah": 114,
      "text": "وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3903,
      "ayahNumberInSurah": 115,
      "text": "وَنَجَّيْنَٰهُمَا وَقَوْمَهُمَا مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3904,
      "ayahNumberInSurah": 116,
      "text": "وَنَصَرْنَٰهُمْ فَكَانُوا۟ هُمُ ٱلْغَٰلِبِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3905,
      "ayahNumberInSurah": 117,
      "text": "وَءَاتَيْنَٰهُمَا ٱلْكِتَٰبَ ٱلْمُسْتَبِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3906,
      "ayahNumberInSurah": 118,
      "text": "وَهَدَيْنَٰهُمَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3907,
      "ayahNumberInSurah": 119,
      "text": "وَتَرَكْنَا عَلَيْهِمَا فِى ٱلْءَاخِرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 450,
      "ruku": 389,
      "hizbQuarter": 180,
      "sajda": false
    },
    {
      "ayahNumber": 3908,
      "ayahNumberInSurah": 120,
      "text": "سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ",
