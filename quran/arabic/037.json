      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3965,
      "ayahNumberInSurah": 177,
      "text": "فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ ٱلْمُنذَرِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3966,
      "ayahNumberInSurah": 178,
      "text": "وَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3967,
      "ayahNumberInSurah": 179,
      "text": "وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَ",
