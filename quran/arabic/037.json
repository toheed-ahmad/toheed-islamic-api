      "ayahNumberInSurah": 161,
      "text": "فَإِنَّكُمْ وَمَا تَعْبُدُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3950,
      "ayahNumberInSurah": 162,
      "text": "مَآ أَنتُمْ عَلَيْهِ بِفَٰتِنِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3951,
      "ayahNumberInSurah": 163,
      "text": "إِلَّا مَنْ هُوَ صَالِ ٱلْجَحِيمِ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3952,
      "ayahNumberInSurah": 164,
      "text": "وَمَا مِنَّآ إِلَّا لَهُۥ مَقَامٌۭ مَّعْلُومٌۭ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3953,
      "ayahNumberInSurah": 165,
      "text": "وَإِنَّا لَنَحْنُ ٱلصَّآفُّونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3954,
      "ayahNumberInSurah": 166,
      "text": "وَإِنَّا لَنَحْنُ ٱلْمُسَبِّحُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3955,
      "ayahNumberInSurah": 167,
      "text": "وَإِن كَانُوا۟ لَيَقُولُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3956,
      "ayahNumberInSurah": 168,
      "text": "لَوْ أَنَّ عِندَنَا ذِكْرًۭا مِّنَ ٱلْأَوَّلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3957,
      "ayahNumberInSurah": 169,
      "text": "لَكُنَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3958,
      "ayahNumberInSurah": 170,
      "text": "فَكَفَرُوا۟ بِهِۦ ۖ فَسَوْفَ يَعْلَمُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3959,
      "ayahNumberInSurah": 171,
      "text": "وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا ٱلْمُرْسَلِينَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3960,
      "ayahNumberInSurah": 172,
      "text": "إِنَّهُمْ لَهُمُ ٱلْمَنصُورُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3961,
      "ayahNumberInSurah": 173,
      "text": "وَإِنَّ جُندَنَا لَهُمُ ٱلْغَٰلِبُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3962,
      "ayahNumberInSurah": 174,
      "text": "فَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍۢ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3963,
      "ayahNumberInSurah": 175,
      "text": "وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ",
      "juz": 23,
      "manzil": 6,
      "page": 452,
      "ruku": 390,
      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3964,
      "ayahNumberInSurah": 176,
      "text": "أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ",
