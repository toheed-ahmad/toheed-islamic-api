      "hizbQuarter": 181,
      "sajda": false
    },
    {
      "ayahNumber": 3968,
      "ayahNumberInSurah": 180,
      "text": "سُبْحَٰنَ رَبِّكَ رَبِّ ٱلْعِزَّةِ عَمَّا يَصِفُونَ",
      "juz": 23,
