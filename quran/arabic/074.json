  "ayahs": [
    {
      "ayahNumber": 5496,
      "ayahNumberInSurah": 1,
      "text": "يَٰٓأَيُّهَا ٱلْمُدَّثِّرُ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5497,
      "ayahNumberInSurah": 2,
      "text": "قُمْ فَأَنذِرْ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5498,
      "ayahNumberInSurah": 3,
      "text": "وَرَبَّكَ فَكَبِّرْ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5499,
      "ayahNumberInSurah": 4,
      "text": "وَثِيَابَكَ فَطَهِّرْ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5500,
      "ayahNumberInSurah": 5,
      "text": "وَٱلرُّجْزَ فَٱهْجُرْ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5501,
      "ayahNumberInSurah": 6,
      "text": "وَلَا تَمْنُن تَسْتَكْثِرُ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5502,
      "ayahNumberInSurah": 7,
      "text": "وَلِرَبِّكَ فَٱصْبِرْ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5503,
      "ayahNumberInSurah": 8,
      "text": "فَإِذَا نُقِرَ فِى ٱلنَّاقُورِ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5504,
      "ayahNumberInSurah": 9,
      "text": "فَذَٰلِكَ يَوْمَئِذٍۢ يَوْمٌ عَسِيرٌ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5505,
      "ayahNumberInSurah": 10,
      "text": "عَلَى ٱلْكَٰفِرِينَ غَيْرُ يَسِيرٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5506,
      "ayahNumberInSurah": 11,
      "text": "ذَرْنِى وَمَنْ خَلَقْتُ وَحِيدًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5507,
      "ayahNumberInSurah": 12,
      "text": "وَجَعَلْتُ لَهُۥ مَالًۭا مَّمْدُودًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5508,
      "ayahNumberInSurah": 13,
      "text": "وَبَنِينَ شُهُودًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5509,
      "ayahNumberInSurah": 14,
      "text": "وَمَهَّدتُّ لَهُۥ تَمْهِيدًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5510,
      "ayahNumberInSurah": 15,
      "text": "ثُمَّ يَطْمَعُ أَنْ أَزِيدَ",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5511,
      "ayahNumberInSurah": 16,
      "text": "كَلَّآ ۖ إِنَّهُۥ كَانَ لِءَايَٰتِنَا عَنِيدًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5512,
      "ayahNumberInSurah": 17,
      "text": "سَأُرْهِقُهُۥ صَعُودًا",
      "juz": 29,
      "manzil": 7,
      "page": 575,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5513,
      "ayahNumberInSurah": 18,
      "text": "إِنَّهُۥ فَكَّرَ وَقَدَّرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5514,
      "ayahNumberInSurah": 19,
      "text": "فَقُتِلَ كَيْفَ قَدَّرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5515,
      "ayahNumberInSurah": 20,
      "text": "ثُمَّ قُتِلَ كَيْفَ قَدَّرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5516,
      "ayahNumberInSurah": 21,
      "text": "ثُمَّ نَظَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5517,
      "ayahNumberInSurah": 22,
      "text": "ثُمَّ عَبَسَ وَبَسَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5518,
      "ayahNumberInSurah": 23,
      "text": "ثُمَّ أَدْبَرَ وَٱسْتَكْبَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5519,
      "ayahNumberInSurah": 24,
      "text": "فَقَالَ إِنْ هَٰذَآ إِلَّا سِحْرٌۭ يُؤْثَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5520,
      "ayahNumberInSurah": 25,
      "text": "إِنْ هَٰذَآ إِلَّا قَوْلُ ٱلْبَشَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5521,
      "ayahNumberInSurah": 26,
      "text": "سَأُصْلِيهِ سَقَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5522,
      "ayahNumberInSurah": 27,
      "text": "وَمَآ أَدْرَىٰكَ مَا سَقَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5523,
      "ayahNumberInSurah": 28,
      "text": "لَا تُبْقِى وَلَا تَذَرُ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5524,
      "ayahNumberInSurah": 29,
      "text": "لَوَّاحَةٌۭ لِّلْبَشَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5525,
      "ayahNumberInSurah": 30,
      "text": "عَلَيْهَا تِسْعَةَ عَشَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5526,
      "ayahNumberInSurah": 31,
      "text": "وَمَا جَعَلْنَآ أَصْحَٰبَ ٱلنَّارِ إِلَّا مَلَٰٓئِكَةًۭ ۙ وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةًۭ لِّلَّذِينَ كَفَرُوا۟ لِيَسْتَيْقِنَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَيَزْدَادَ ٱلَّذِينَ ءَامَنُوٓا۟ إِيمَٰنًۭا ۙ وَلَا يَرْتَابَ ٱلَّذِينَ أُوتُوا۟ ٱلْكِتَٰبَ وَٱلْمُؤْمِنُونَ ۙ وَلِيَقُولَ ٱلَّذِينَ فِى قُلُوبِهِم مَّرَضٌۭ وَٱلْكَٰفِرُونَ مَاذَآ أَرَادَ ٱللَّهُ بِهَٰذَا مَثَلًۭا ۚ كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهْدِى مَن يَشَآءُ ۚ وَمَا يَعْلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَ ۚ وَمَا هِىَ إِلَّا ذِكْرَىٰ لِلْبَشَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 510,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5527,
      "ayahNumberInSurah": 32,
      "text": "كَلَّا وَٱلْقَمَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5528,
      "ayahNumberInSurah": 33,
      "text": "وَٱلَّيْلِ إِذْ أَدْبَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5529,
      "ayahNumberInSurah": 34,
      "text": "وَٱلصُّبْحِ إِذَآ أَسْفَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5530,
      "ayahNumberInSurah": 35,
      "text": "إِنَّهَا لَإِحْدَى ٱلْكُبَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5531,
      "ayahNumberInSurah": 36,
      "text": "نَذِيرًۭا لِّلْبَشَرِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5532,
      "ayahNumberInSurah": 37,
      "text": "لِمَن شَآءَ مِنكُمْ أَن يَتَقَدَّمَ أَوْ يَتَأَخَّرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5533,
      "ayahNumberInSurah": 38,
      "text": "كُلُّ نَفْسٍۭ بِمَا كَسَبَتْ رَهِينَةٌ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5534,
      "ayahNumberInSurah": 39,
      "text": "إِلَّآ أَصْحَٰبَ ٱلْيَمِينِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5535,
      "ayahNumberInSurah": 40,
      "text": "فِى جَنَّٰتٍۢ يَتَسَآءَلُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5536,
      "ayahNumberInSurah": 41,
      "text": "عَنِ ٱلْمُجْرِمِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5537,
      "ayahNumberInSurah": 42,
      "text": "مَا سَلَكَكُمْ فِى سَقَرَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5538,
      "ayahNumberInSurah": 43,
      "text": "قَالُوا۟ لَمْ نَكُ مِنَ ٱلْمُصَلِّينَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5539,
      "ayahNumberInSurah": 44,
      "text": "وَلَمْ نَكُ نُطْعِمُ ٱلْمِسْكِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5540,
      "ayahNumberInSurah": 45,
      "text": "وَكُنَّا نَخُوضُ مَعَ ٱلْخَآئِضِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5541,
      "ayahNumberInSurah": 46,
      "text": "وَكُنَّا نُكَذِّبُ بِيَوْمِ ٱلدِّينِ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5542,
      "ayahNumberInSurah": 47,
      "text": "حَتَّىٰٓ أَتَىٰنَا ٱلْيَقِينُ",
      "juz": 29,
      "manzil": 7,
      "page": 576,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5543,
      "ayahNumberInSurah": 48,
      "text": "فَمَا تَنفَعُهُمْ شَفَٰعَةُ ٱلشَّٰفِعِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5544,
      "ayahNumberInSurah": 49,
      "text": "فَمَا لَهُمْ عَنِ ٱلتَّذْكِرَةِ مُعْرِضِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5545,
      "ayahNumberInSurah": 50,
      "text": "كَأَنَّهُمْ حُمُرٌۭ مُّسْتَنفِرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5546,
      "ayahNumberInSurah": 51,
      "text": "فَرَّتْ مِن قَسْوَرَةٍۭ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5547,
      "ayahNumberInSurah": 52,
      "text": "بَلْ يُرِيدُ كُلُّ ٱمْرِئٍۢ مِّنْهُمْ أَن يُؤْتَىٰ صُحُفًۭا مُّنَشَّرَةًۭ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5548,
      "ayahNumberInSurah": 53,
      "text": "كَلَّا ۖ بَل لَّا يَخَافُونَ ٱلْءَاخِرَةَ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5549,
      "ayahNumberInSurah": 54,
      "text": "كَلَّآ إِنَّهُۥ تَذْكِرَةٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5550,
      "ayahNumberInSurah": 55,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    },
    {
      "ayahNumber": 5551,
      "ayahNumberInSurah": 56,
      "text": "وَمَا يَذْكُرُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ هُوَ أَهْلُ ٱلتَّقْوَىٰ وَأَهْلُ ٱلْمَغْفِرَةِ",
      "juz": 29,
      "manzil": 7,
      "page": 577,
      "ruku": 511,
      "hizbQuarter": 230,
      "sajda": false
    }
  ]
