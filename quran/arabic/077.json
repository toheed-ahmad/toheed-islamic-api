      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5658,
      "ayahNumberInSurah": 36,
      "text": "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5659,
      "ayahNumberInSurah": 37,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
