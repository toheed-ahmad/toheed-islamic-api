      "ayahNumberInSurah": 34,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5657,
      "ayahNumberInSurah": 35,
      "text": "هَٰذَا يَوْمُ لَا يَنطِقُونَ",
