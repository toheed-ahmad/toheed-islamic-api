  "ayahs": [
    {
      "ayahNumber": 5623,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْمُرْسَلَٰتِ عُرْفًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5624,
      "ayahNumberInSurah": 2,
      "text": "فَٱلْعَٰصِفَٰتِ عَصْفًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5625,
      "ayahNumberInSurah": 3,
      "text": "وَٱلنَّٰشِرَٰتِ نَشْرًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5626,
      "ayahNumberInSurah": 4,
      "text": "فَٱلْفَٰرِقَٰتِ فَرْقًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5627,
      "ayahNumberInSurah": 5,
      "text": "فَٱلْمُلْقِيَٰتِ ذِكْرًا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5628,
      "ayahNumberInSurah": 6,
      "text": "عُذْرًا أَوْ نُذْرًا",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5629,
      "ayahNumberInSurah": 7,
      "text": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٌۭ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5630,
      "ayahNumberInSurah": 8,
      "text": "فَإِذَا ٱلنُّجُومُ طُمِسَتْ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5631,
      "ayahNumberInSurah": 9,
      "text": "وَإِذَا ٱلسَّمَآءُ فُرِجَتْ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5632,
      "ayahNumberInSurah": 10,
      "text": "وَإِذَا ٱلْجِبَالُ نُسِفَتْ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5633,
      "ayahNumberInSurah": 11,
      "text": "وَإِذَا ٱلرُّسُلُ أُقِّتَتْ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5634,
      "ayahNumberInSurah": 12,
      "text": "لِأَىِّ يَوْمٍ أُجِّلَتْ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5635,
      "ayahNumberInSurah": 13,
      "text": "لِيَوْمِ ٱلْفَصْلِ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5636,
      "ayahNumberInSurah": 14,
      "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5637,
      "ayahNumberInSurah": 15,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5638,
      "ayahNumberInSurah": 16,
      "text": "أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5639,
      "ayahNumberInSurah": 17,
      "text": "ثُمَّ نُتْبِعُهُمُ ٱلْءَاخِرِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5640,
      "ayahNumberInSurah": 18,
      "text": "كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5641,
      "ayahNumberInSurah": 19,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 580,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5642,
      "ayahNumberInSurah": 20,
      "text": "أَلَمْ نَخْلُقكُّم مِّن مَّآءٍۢ مَّهِينٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5643,
      "ayahNumberInSurah": 21,
      "text": "فَجَعَلْنَٰهُ فِى قَرَارٍۢ مَّكِينٍ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5644,
      "ayahNumberInSurah": 22,
      "text": "إِلَىٰ قَدَرٍۢ مَّعْلُومٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5645,
      "ayahNumberInSurah": 23,
      "text": "فَقَدَرْنَا فَنِعْمَ ٱلْقَٰدِرُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5646,
      "ayahNumberInSurah": 24,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5647,
      "ayahNumberInSurah": 25,
      "text": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5648,
      "ayahNumberInSurah": 26,
      "text": "أَحْيَآءًۭ وَأَمْوَٰتًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5649,
      "ayahNumberInSurah": 27,
      "text": "وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَٰمِخَٰتٍۢ وَأَسْقَيْنَٰكُم مَّآءًۭ فُرَاتًۭا",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5650,
      "ayahNumberInSurah": 28,
      "text": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5651,
      "ayahNumberInSurah": 29,
      "text": "ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5652,
      "ayahNumberInSurah": 30,
      "text": "ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّۢ ذِى ثَلَٰثِ شُعَبٍۢ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5653,
      "ayahNumberInSurah": 31,
      "text": "لَّا ظَلِيلٍۢ وَلَا يُغْنِى مِنَ ٱللَّهَبِ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5654,
      "ayahNumberInSurah": 32,
      "text": "إِنَّهَا تَرْمِى بِشَرَرٍۢ كَٱلْقَصْرِ",
      "juz": 29,
      "manzil": 7,
      "page": 581,
      "ruku": 516,
      "hizbQuarter": 232,
      "sajda": false
    },
    {
      "ayahNumber": 5655,
      "ayahNumberInSurah": 33,
      "text": "كَأَنَّهُۥ جِمَٰلَتٌۭ صُفْرٌۭ",
