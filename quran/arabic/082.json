  "ayahs": [
    {
      "ayahNumber": 5830,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5831,
      "ayahNumberInSurah": 2,
      "text": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5832,
      "ayahNumberInSurah": 3,
      "text": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5833,
      "ayahNumberInSurah": 4,
      "text": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5834,
      "ayahNumberInSurah": 5,
      "text": "عَلِمَتْ نَفْسٌۭ مَّا قَدَّمَتْ وَأَخَّرَتْ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5835,
      "ayahNumberInSurah": 6,
      "text": "يَٰٓأَيُّهَا ٱلْإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5836,
      "ayahNumberInSurah": 7,
      "text": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5837,
      "ayahNumberInSurah": 8,
      "text": "فِىٓ أَىِّ صُورَةٍۢ مَّا شَآءَ رَكَّبَكَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5838,
      "ayahNumberInSurah": 9,
      "text": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5839,
      "ayahNumberInSurah": 10,
      "text": "وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5840,
      "ayahNumberInSurah": 11,
      "text": "كِرَامًۭا كَٰتِبِينَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5841,
      "ayahNumberInSurah": 12,
      "text": "يَعْلَمُونَ مَا تَفْعَلُونَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5842,
      "ayahNumberInSurah": 13,
      "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5843,
      "ayahNumberInSurah": 14,
      "text": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍۢ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5844,
      "ayahNumberInSurah": 15,
      "text": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5845,
      "ayahNumberInSurah": 16,
      "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
      "juz": 30,
      "manzil": 7,
      "page": 587,
      "ruku": 524,
      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5846,
      "ayahNumberInSurah": 17,
      "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
