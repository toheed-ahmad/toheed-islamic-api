      "hizbQuarter": 235,
      "sajda": false
    },
    {
      "ayahNumber": 5847,
      "ayahNumberInSurah": 18,
      "text": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
