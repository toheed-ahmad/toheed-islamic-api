      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5961,
      "ayahNumberInSurah": 13,
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5962,
      "ayahNumberInSurah": 14,
      "text": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
