      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5950,
      "ayahNumberInSurah": 2,
      "text": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5951,
      "ayahNumberInSurah": 3,
      "text": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5952,
      "ayahNumberInSurah": 4,
      "text": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5953,
      "ayahNumberInSurah": 5,
      "text": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5954,
      "ayahNumberInSurah": 6,
      "text": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5955,
      "ayahNumberInSurah": 7,
      "text": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5956,
      "ayahNumberInSurah": 8,
      "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5957,
      "ayahNumberInSurah": 9,
      "text": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5958,
      "ayahNumberInSurah": 10,
      "text": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5959,
      "ayahNumberInSurah": 11,
      "text": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "juz": 30,
      "manzil": 7,
      "page": 591,
      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5960,
      "ayahNumberInSurah": 12,
      "text": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "juz": 30,
      "manzil": 7,
