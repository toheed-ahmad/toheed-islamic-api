      "ruku": 529,
      "hizbQuarter": 237,
      "sajda": false
    },
    {
      "ayahNumber": 5963,
      "ayahNumberInSurah": 15,
      "text": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
