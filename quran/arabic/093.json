  "ayahs": [
    {
      "ayahNumber": 6080,
      "ayahNumberInSurah": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
