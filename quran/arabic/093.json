      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6081,
      "ayahNumberInSurah": 2,
      "text": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6082,
      "ayahNumberInSurah": 3,
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6083,
      "ayahNumberInSurah": 4,
      "text": "وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6084,
      "ayahNumberInSurah": 5,
      "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6085,
      "ayahNumberInSurah": 6,
      "text": "أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6086,
      "ayahNumberInSurah": 7,
      "text": "وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6087,
      "ayahNumberInSurah": 8,
      "text": "وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ",
      "juz": 30,
      "manzil": 7,
      "page": 596,
      "ruku": 535,
      "hizbQuarter": 238,
      "sajda": false
    },
    {
      "ayahNumber": 6088,
      "ayahNumberInSurah": 9,
      "text": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
